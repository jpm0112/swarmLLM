    approach: Adaptive LNS-SA hybrid combining CP-SAT initialization with Large Neighborhood Search and Simulated Annealing for critical path swaps
    code: "from ortools.sat.python import cp_model\nimport time\nimport random\nimport math\n\nTIMEOUT_SEC = 120\n_START_TIME = time.time()\n\ndef solve(jobs: list[list[dict]]) -> list[list[dict]]:\n    # Extract problem data\n    num_jobs = len(jobs)\n    num_machines = max(max(op['machine'] for op in job) for job in jobs) + 1\n    \n    # Initialize CP-SAT model and get initial solution\n    initial_schedule, initial_makespan = solve_with_cp(jobs, num_jobs, num_machines)\n    \n    # Set initial best solution\n    best_schedule = [job.copy() for job in initial_schedule]\n    best_makespan = initial_makespan\n    \n    # Hybrid LNS-SA parameters\n    max_iterations = 100\n    relaxation_size = max(1, num_jobs // 5)\n    initial_temp = 1000\n    final_temp = 1\n    cooling_rate = 0.995\n    current_temp = initial_temp\n    \n    # Main hybrid loop\n    for iteration in range(max_iterations):\n        # Check for timeout\n        if time.time() - _START_TIME > 0.8 * TIMEOUT_SEC:\n            break\n        \n        # Select a subset of jobs to relax (randomly)\n        jobs_to_relax = random.sample(range(num_jobs), min(relaxation_size, num_jobs))\n        \n        # Solve relaxed problem with CP-SAT\n        relaxed_schedule, relaxed_makespan = solve_relaxed_cp(\n            jobs, num_jobs, num_machines, jobs_to_relax, best_schedule\n        )\n        \n        # Apply Simulated Annealing to the relaxed solution\n        sa_schedule, sa_makespan = simulated_annealing_step(\n            relaxed_schedule, jobs, current_temp\n        )\n        \n        # Accept if improved or with SA probability\n        if sa_makespan < best_makespan or random.random() < math.exp((best_makespan - sa_makespan) / current_temp):\n            best_schedule = [job.copy() for job in sa_schedule]\n            best_makespan = sa_makespan\n        \n        # Cool down temperature\n        current_temp *= cooling_rate\n        \n        # Adjust relaxation size based on progress\n        if iteration % 10 == 0:\n            if best_makespan < initial_makespan * 0.95:\n                relaxation_size = max(1, relaxation_size - 1)\n            else:\n                relaxation_size = min(num_jobs - 1, relaxation_size + 1)\n    \n    return best_schedule\n\ndef solve_with_cp(jobs, num_jobs, num_machines):\n    \"\"\"Solve the full problem with CP-SAT to get initial solution\"\"\"\n    model = cp_model.CpModel()\n    all_ops = []\n    \n    for job_idx, job in enumerate(jobs):\n        for op_idx, op in enumerate(job):\n            start_var = model.NewIntVar(0, 1000000, f'start_{job_idx}_{op_idx}')\n            duration = op['duration']\n            end_var = model.NewIntVar(0, 1000000, f'end_{job_idx}_{op_idx}')\n            model.Add(end_var == start_var + duration)\n            \n            all_ops.append({\n                'job': job_idx,\n                'op': op_idx,\n                'machine': op['machine'],\n                'start': start_var,\n                'end': end_var,\n                'duration': duration\n            })\n    \n    # Precedence constraints\n    for job_idx, job in enumerate(jobs):\n        for op_idx in range(1, len(job)):\n            prev_op = all_ops[job_idx * len(job) + op_idx - 1]\n            curr_op = all_ops[job_idx * len(job) + op_idx]\n            model.Add(curr_op['start'] >= prev_op['end'])\n    \n    # Machine constraints\n    for machine in range(num_machines):\n        machine_ops = [op for op in all_ops if op['machine'] == machine]\n        if machine_ops:\n            intervals = []\n            for op in machine_ops:\n                interval = model.NewIntervalVar(op['start'], op['duration'], op['end'],\n                                               f'interval_{op[\"job\"]}_{op[\"op\"]}')\n                intervals.append(interval)\n            model.AddNoOverlap(intervals)\n    \n    # Objective\n    makespan = model.NewIntVar(0, 1000000, 'makespan')\n    model.AddMaxEquality(makespan, [op['end'] for op in all_ops])\n    model.Minimize(makespan)\n    \n    # Solve\n    solver = cp_model.CpSolver()\n    remaining_time = TIMEOUT_SEC - (time.time() - _START_TIME)\n    solver.parameters.max_time_in_seconds = 0.1 * remaining_time\n    \n    status = solver.Solve(model)\n    \n    # Build solution\n    schedule = []\n    for job_idx, job in enumerate(jobs):\n        scheduled_job = []\n        for op_idx, op in enumerate(job):\n            op_start = solver.Value(all_ops[job_idx * len(job) + op_idx]['start'])\n            scheduled_op = {\n                'machine': op['machine'],\n                'duration': op['duration'],\n                'start': op_start\n            }\n            scheduled_job.append(scheduled_op)\n        schedule.append(scheduled_job)\n    \n    makespan = max(op['start'] + op['duration'] for job in schedule for op in job)\n    return schedule, makespan\n\ndef solve_relaxed_cp(jobs, num_jobs, num_machines, jobs_to_relax, reference_schedule):\n    \"\"\"Solve with some start times fixed (LNS relaxation)\"\"\"\n    model = cp_model.CpModel()\n    all_ops = []\n    \n    for job_idx, job in enumerate(jobs):\n        for op_idx, op in enumerate(job):\n            if job_idx in jobs_to_relax:\n                start_var = model.NewIntVar(0, 1000000, f'start_{job_idx}_{op_idx}')\n            else:\n                ref_start = reference_schedule[job_idx][op_idx]['start']\n                start_var = model.NewConstant(ref_start)\n            \n            duration = op['duration']\n            end_var = model.NewIntVar(0, 1000000, f'end_{job_idx}_{op_idx}')\n            model.Add(end_var == start_var + duration)\n            \n            all_ops.append({\n                'job': job_idx,\n                'op': op_idx,\n                'machine': op['machine'],\n                'start': start_var,\n                'end': end_var,\n                'duration': duration\n            })\n    \n    # Precedence constraints (only for relaxed jobs)\n    for job_idx in jobs_to_relax:\n        job = jobs[job_idx]\n        for op_idx in range(1, len(job)):\n            prev_op = all_ops[job_idx * len(job) + op_idx - 1]\n            curr_op = all_ops[job_idx * len(job) + op_idx]\n            model.Add(curr_op['start'] >= prev_op['end'])\n    \n    # Machine constraints (only for machines used by relaxed jobs)\n    for machine in range(num_machines):\n        machine_ops = [op for op in all_ops if op['machine'] == machine]\n        if any(op['job'] in jobs_to_relax for op in machine_ops):\n            intervals = []\n            for op in machine_ops:\n                interval = model.NewIntervalVar(op['start'], op['duration'], op['end'],\n                                               f'interval_{op[\"job\"]}_{op[\"op\"]}')\n                intervals.append(interval)\n            model.AddNoOverlap(intervals)\n    \n    # Objective\n    makespan = model.NewIntVar(0, 1000000, 'makespan')\n    model.AddMaxEquality(makespan, [op['end'] for op in all_ops if op['job'] in jobs_to_relax])\n    model.Minimize(makespan)\n    \n    # Solve with shorter time limit\n    solver = cp_model.CpSolver()\n    remaining_time = TIMEOUT_SEC - (time.time() - _START_TIME)\n    solver.parameters.max_time_in_seconds = 0.05 * remaining_time\n    \n    status = solver.Solve(model)\n    \n    # Build solution\n    schedule = []\n    for job_idx, job in enumerate(jobs):\n        scheduled_job = []\n        for op_idx, op in enumerate(job):\n            if job_idx in jobs_to_relax:\n                op_start = solver.Value(all_ops[job_idx * len(job) + op_idx]['start'])\n            else:\n                op_start = reference_schedule[job_idx][op_idx]['start']\n            \n            scheduled_op = {\n                'machine': op['machine'],\n                'duration': op['duration'],\n                'start': op_start\n            }\n            scheduled_job.append(scheduled_op)\n        schedule.append(scheduled_job)\n    \n    makespan = max(op['start'] + op['duration'] for job in schedule for op in job)\n    return schedule, makespan\n\ndef simulated_annealing_step(schedule, jobs, temperature):\n    \"\"\"Apply one step of Simulated Annealing focusing on critical path swaps\"\"\"\n    current_solution = [op.copy() for job in schedule for op in job]\n    current_makespan = compute_makespan(current_solution)\n    \n    # Find critical path operations\n    critical_ops = find_critical_path(current_solution)\n    \n    if len(critical_ops) < 2:\n        return schedule, current_makespan\n    \n    # Try multiple swaps and pick the best\n    best_neighbor = None\n    best_makespan = current_makespan\n    \n    for _ in range(5):  # Try 5 different swaps\n        # Select two random operations on critical path from different jobs\n        i, j = random.sample(range(len(critical_ops)), 2)\n        op1 = critical_ops[i]\n        op2 = critical_ops[j]\n        \n        # Check if they can be swapped\n        if op1['machine'] == op2['machine'] and op1['job'] != op2['job']:\n            if can_swap(current_solution, op1, op2):\n                new_solution = [op.copy() for op in current_solution]\n                \n                # Swap the operations\n                idx1 = current_solution.index(op1)\n                idx2 = current_solution.index(op2)\n                new_solution[idx1], new_solution[idx2] = new_solution[idx2], new_solution[idx1]\n                \n                # Recompute start times\n                new_solution = recompute_start_times(new_solution, jobs)\n                neighbor_makespan = compute_makespan(new_solution)\n                \n                # Accept if better or with SA probability\n                if neighbor_makespan < best_makespan or random.random() < math.exp((best_makespan - neighbor_makespan) / temperature):\n                    best_neighbor = new_solution\n                    best_makespan = neighbor_makespan\n    \n    if best_neighbor is not None:\n        # Reconstruct job structure\n        solution = []\n        op_index = 0\n        for job in jobs:\n            scheduled_job = []\n            for _ in job:\n                scheduled_job.append(best_neighbor[op_index])\n                op_index += 1\n            solution.append(scheduled_job)\n        return solution, best_makespan\n    \n    return schedule, current_makespan\n\ndef find_critical_path(solution):\n    \"\"\"Find operations on the critical path\"\"\"\n    makespan = max(op['start'] + op['duration'] for op in solution)\n    critical_ops = [op for op in solution if op['start'] + op['duration'] == makespan]\n    \n    # If multiple operations finish at makespan, pick one path\n    if critical_ops:\n        return critical_ops\n    \n    return []\n\ndef can_swap(solution, op1, op2):\n    \"\"\"Check if swapping maintains precedence constraints\"\"\"\n    job1_ops = [op for op in solution if op['job'] == op1['job']]\n    job2_ops = [op for op in solution if op['job'] == op2['job']]\n    \n    pos1_in_job = job1_ops.index(op1)\n    pos2_in_job = job2_ops.index(op2)\n    \n    # Check if op1 is the last operation in its job or op2 comes after op1's successor\n    if pos1_in_job < len(job1_ops) - 1:\n        next_op1 = job1_ops[pos1_in_job + 1]\n        if next_op1['start'] < op2['start'] + op2['duration']:\n            return False\n    \n    # Check if op2 is the last operation in its job or op1 comes after op2's successor\n    if pos2_in_job < len(job2_ops) - 1:\n        next_op2 = job2_ops[pos2_in_job + 1]\n        if next_op2['start'] < op1['start'] + op1['duration']:\n            return False\n    \n    return True\n\ndef recompute_start_times(solution, jobs):\n    \"\"\"Recompute start times while maintaining feasibility\"\"\"\n    num_jobs = len(jobs)\n    num_machines = max(op['machine'] for op in solution) + 1\n    \n    machine_avail = [0] * num_machines\n    \n    # Process operations in order of their start times\n    sorted_ops = sorted(solution, key=lambda x: x['start'])\n    \n    for op in sorted_ops:\n        m = op['machine']\n        job_ops = [o for o in solution if o['job'] == op['job']]\n        pos_in_job = job_ops.index(op)\n        \n        if pos_in_job == 0:\n            prev_completion = 0\n        else:\n            prev_op = job_ops[pos_in_job - 1]\n            prev_completion = prev_op['start'] + prev_op['duration']\n        \n        op['start'] = max(prev_completion, machine_avail[m])\n        machine_avail[m] = op['start'] + op['duration']\n    \n    return solution\n\ndef compute_makespan(solution):\n    \"\"\"Compute the makespan of a solution\"\"\"\n    return max(op['start'] + op['duration'] for op in solution)"
