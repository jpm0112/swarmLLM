    approach: Hybrid CP-SAT with Beam Search and Greedy Fallback
    code: "import heapq\nimport time\nfrom collections import defaultdict\nfrom ortools.sat.python import cp_model\n\ndef solve(jobs: list[list[dict]]) -> list[list[dict]]:\n    num_jobs = len(jobs)\n    if num_jobs == 0:\n        return []\n    num_machines = max(max(op['machine'] for op in job) for job in jobs) + 1\n    \n    # Precompute operation indices for each job\n    job_ops = [[(op['machine'], op['duration'], idx) for idx, op in enumerate(job)] for job in jobs]\n    \n    # CP-SAT model for warm start\n    model = cp_model.CpModel()\n    \n    # Variables\n    horizon = sum(sum(op['duration'] for op in job) for job in jobs)\n    all_ops = []\n    for job_idx in range(num_jobs):\n        for op_idx in range(len(jobs[job_idx])):\n            op = jobs[job_idx][op_idx]\n            suffix = f\"_job{job_idx}_op{op_idx}\"\n            start = model.NewIntVar(0, horizon, f\"start{suffix}\")\n            end = model.NewIntVar(0, horizon, f\"end{suffix}\")\n            all_ops.append((job_idx, op_idx, start, end))\n            model.Add(end == start + op['duration'])\n    \n    # Constraints\n    for job_idx, op_idx, start, end in all_ops:\n        if op_idx > 0:\n            prev_end = [e for j, o, s, e in all_ops if j == job_idx and o == op_idx - 1][0]\n            model.Add(start >= prev_end)\n    \n    for machine in range(num_machines):\n        intervals = []\n        for job_idx, op_idx, start, end in all_ops:\n            if jobs[job_idx][op_idx]['machine'] == machine:\n                interval = model.NewIntervalVar(start, jobs[job_idx][op_idx]['duration'], end, f\"interval_job{job_idx}_op{op_idx}\")\n                intervals.append(interval)\n        model.AddNoOverlap(intervals)\n    \n    # Objective\n    makespan = model.NewIntVar(0, horizon, \"makespan\")\n    model.AddMaxEquality(makespan, [end for _, _, _, end in all_ops])\n    model.Minimize(makespan)\n    \n    # Solve CP model\n    solver = cp_model.CpSolver()\n    solver.parameters.max_time_in_seconds = 5.0\n    status = solver.Solve(model)\n    \n    # Extract CP solution for warm start\n    cp_schedule = [[] for _ in range(num_jobs)]\n    if status == cp_model.OPTIMAL or status == cp_model.FEASIBLE:\n        for job_idx, op_idx, start, end in all_ops:\n            cp_schedule[job_idx].append({\n                'machine': jobs[job_idx][op_idx]['machine'],\n                'duration': jobs[job_idx][op_idx]['duration'],\n                'start': solver.Value(start)\n            })\n    \n    # Beam search parameters\n    beam_width = 50\n    max_time = 120.0\n    start_time = time.time()\n    \n    # Priority queue: (makespan, machine_times, next_op, schedule, cp_priority)\n    heap = []\n    \n    # Initialize with CP solution if available\n    if cp_schedule and all(len(s) == len(job) for s, job in zip(cp_schedule, jobs)):\n        machine_times = [0] * num_machines\n        for job in cp_schedule:\n            for op in job:\n                machine = op['machine']\n                end = op['start'] + op['duration']\n                if end > machine_times[machine]:\n                    machine_times[machine] = end\n        heapq.heappush(heap, (max(op['start'] + op['duration'] for job in cp_schedule for op in job), \n                            machine_times, [len(job) for job in cp_schedule], cp_schedule, 0))\n    else:\n        # Fallback initialization\n        initial_machine_times = [0] * num_machines\n        initial_next_op = [0] * num_jobs\n        initial_schedule = [[] for _ in range(num_jobs)]\n        heapq.heappush(heap, (0, initial_machine_times, initial_next_op, initial_schedule, 0))\n    \n    best_makespan = float('inf')\n    best_schedule = None\n    \n    while heap and (time.time() - start_time) < 0.8 * max_time:\n        current_makespan, machine_times, next_op, schedule, cp_priority = heapq.heappop(heap)\n        \n        # Check completion\n        if all(idx == len(job) for idx, job in zip(next_op, job_ops)):\n            if current_makespan < best_makespan:\n                best_makespan = current_makespan\n                best_schedule = schedule\n            continue\n        \n        # Generate candidates with CP-inspired priority\n        candidates = []\n        for job_idx in range(num_jobs):\n            if next_op[job_idx] < len(job_ops[job_idx]):\n                machine, duration, op_idx = job_ops[job_idx][next_op[job_idx]]\n                \n                # Job availability\n                if next_op[job_idx] > 0:\n                    job_available = schedule[job_idx][-1]['start'] + schedule[job_idx][-1]['duration']\n                else:\n                    job_available = 0\n                \n                # Earliest start\n                start_time_op = max(machine_times[machine], job_available)\n                end_time_op = start_time_op + duration\n                \n                # CP-inspired priority (lower is better)\n                priority = end_time_op + (0.1 * cp_priority)\n                \n                # Create new state\n                new_machine_times = machine_times.copy()\n                new_machine_times[machine] = end_time_op\n                \n                new_next_op = next_op.copy()\n                new_next_op[job_idx] += 1\n                \n                new_schedule = [op.copy() for op in schedule[job_idx]]\n                new_schedule.append({\n                    'machine': machine,\n                    'duration': duration,\n                    'start': start_time_op\n                })\n                \n                new_state_schedule = [op.copy() for op in schedule]\n                new_state_schedule[job_idx] = new_schedule\n                \n                candidates.append((priority, end_time_op, (new_machine_times, new_next_op, new_state_schedule, cp_priority + 1)))\n        \n        # Select top candidates\n        if candidates:\n            candidates.sort()\n            for _, makespan, state in candidates[:beam_width]:\n                heapq.heappush(heap, (makespan,) + state)\n    \n    # Return best solution found\n    if best_schedule is not None:\n        return best_schedule\n    \n    # Fallback greedy if needed\n    machine_available = [0] * num_machines\n    job_next_op = [0] * num_jobs\n    job_available = [0] * num_jobs\n    schedule = [[] for _ in range(num_jobs)]\n    \n    while any(job_next_op[job_idx] < len(jobs[job_idx]) for job_idx in range(num_jobs)):\n        schedulable = []\n        for job_idx in range(num_jobs):\n            if job_next_op[job_idx] < len(jobs[job_idx]):\n                op = jobs[job_idx][job_next_op[job_idx]]\n                machine = op['machine']\n                duration = op['duration']\n                \n                start_time = max(job_available[job_idx], machine_available[machine])\n                schedulable.append((start_time, job_idx, machine, duration))\n        \n        if not schedulable:\n            break\n        \n        schedulable.sort()\n        start_time, job_idx, machine, duration = schedulable[0]\n        \n        machine_available[machine] = start_time + duration\n        job_available[job_idx] = start_time + duration\n        job_next_op[job_idx] += 1\n        \n        schedule[job_idx].append({\n            'machine': machine,\n            'duration': duration,\n            'start': start_time\n        })\n    \n    return schedule"
