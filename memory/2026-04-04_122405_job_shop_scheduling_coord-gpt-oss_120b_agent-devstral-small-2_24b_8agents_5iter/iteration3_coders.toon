    approach: Ant Colony Optimization with CP-SAT initialization and local repair
    code: "import time\nimport random\nimport numpy as np\nfrom ortools.sat.python import cp_model\n\n# Pre-defined globals for timeout handling\nTIMEOUT_SEC = 120\n_START_TIME = time.time()\n\nclass AntColonyScheduler:\n    def __init__(self, jobs, n_ants=20, evaporation=0.5, alpha=1.0, beta=2.0):\n        self.jobs = jobs\n        self.n_jobs = len(jobs)\n        self.n_machines = max(max(op['machine'] for op in job) for job in jobs) + 1\n        self.n_ants = n_ants\n        self.evaporation = evaporation\n        self.alpha = alpha  # pheromone importance\n        self.beta = beta    # heuristic importance\n        \n        # Initialize pheromones: [job][position] -> pheromone level\n        self.pheromones = np.ones((self.n_jobs, self.n_jobs))\n        self.best_schedule = None\n        self.best_makespan = float('inf')\n        \n        # Heuristic: 1 / (processing time on critical machine)\n        self.heuristic = self._compute_heuristic()\n    \n    def _compute_heuristic(self):\n        \"\"\"Compute heuristic values based on processing times\"\"\"\n        heuristic = np.zeros((self.n_jobs, self.n_jobs))\n        for i in range(self.n_jobs):\n            for j in range(self.n_jobs):\n                if i == j:\n                    continue\n                # Use total processing time as heuristic base\n                total_time_i = sum(op['duration'] for op in self.jobs[i])\n                total_time_j = sum(op['duration'] for op in self.jobs[j])\n                heuristic[i][j] = 1.0 / (total_time_i + total_time_j + 1e-6)\n        return heuristic\n    \n    def _construct_schedule(self):\n        \"\"\"Construct a schedule using ACO rules\"\"\"\n        order = []\n        available_jobs = list(range(self.n_jobs))\n        \n        while available_jobs:\n            # Calculate probabilities for each available job\n            probabilities = []\n            for job in available_jobs:\n                if order:\n                    pheromone = np.mean(self.pheromones[job, order])\n                    heuristic_val = np.mean(self.heuristic[job, order])\n                else:\n                    pheromone = 1.0\n                    heuristic_val = 1.0\n                \n                # ACO probability formula\n                prob = (pheromone ** self.alpha) * (heuristic_val ** self.beta)\n                probabilities.append(prob)\n            \n            # Convert to probabilities\n            total = sum(probabilities)\n            if total > 0:\n                probabilities = [p / total for p in probabilities]\n            else:\n                probabilities = [1.0 / len(probabilities)] * len(probabilities)\n            \n            # Select next job\n            selected = random.choices(available_jobs, weights=probabilities, k=1)[0]\n            order.append(selected)\n            available_jobs.remove(selected)\n        \n        return order\n    \n    def _schedule_from_order(self, job_order):\n        \"\"\"Convert job order to a schedule with start times\"\"\"\n        # Initialize machine timelines\n        machine_timelines = [0] * self.n_machines\n        job_completion = [0] * self.n_jobs\n        \n        # Create a copy of jobs to add start times\n        scheduled_jobs = [job.copy() for job in self.jobs]\n        \n        for job_idx in job_order:\n            job = self.jobs[job_idx]\n            for op_idx, op in enumerate(job):\n                machine = op['machine']\n                duration = op['duration']\n                \n                # Start time is max of machine availability and previous operation completion\n                start = max(machine_timelines[machine], job_completion[job_idx])\n                \n                # Update timelines\n                machine_timelines[machine] = start + duration\n                job_completion[job_idx] = start + duration\n                \n                # Add start time to operation\n                scheduled_jobs[job_idx][op_idx]['start'] = start\n        \n        makespan = max(job_completion)\n        return scheduled_jobs, makespan\n    \n    def _local_repair(self, schedule):\n        \"\"\"Apply local repair to improve schedule feasibility\"\"\"\n        # Simple swap repair\n        improved = True\n        best_schedule = schedule\n        best_makespan = self._calculate_makespan(schedule)\n        \n        while improved and (time.time() - _START_TIME) < 0.8 * TIMEOUT_SEC:\n            improved = False\n            \n            # Try swapping adjacent jobs\n            for i in range(self.n_jobs - 1):\n                new_schedule = [job.copy() for job in schedule]\n                # Swap job orders\n                new_schedule[i], new_schedule[i+1] = new_schedule[i+1], new_schedule[i]\n                \n                new_makespan = self._calculate_makespan(new_schedule)\n                if new_makespan < best_makespan:\n                    best_makespan = new_makespan\n                    best_schedule = new_schedule\n                    improved = True\n                    break\n        \n        return best_schedule\n    \n    def _calculate_makespan(self, schedule):\n        \"\"\"Calculate makespan for a given schedule\"\"\"\n        machine_timelines = [0] * self.n_machines\n        \n        for job in schedule:\n            prev_end = 0\n            for op in job:\n                machine = op['machine']\n                duration = op['duration']\n                start = max(machine_timelines[machine], prev_end)\n                machine_timelines[machine] = start + duration\n                prev_end = start + duration\n        \n        return max(machine_timelines)\n    \n    def _update_pheromones(self, schedule, makespan):\n        \"\"\"Update pheromones based on solution quality\"\"\"\n        # Evaporate pheromones\n        self.pheromones *= (1 - self.evaporation)\n        \n        # Get job order from schedule\n        job_order = [i for i in range(self.n_jobs)]\n        # Sort by first operation start time to get approximate order\n        job_order.sort(key=lambda i: schedule[i][0]['start'])\n        \n        # Deposit pheromones based on solution quality\n        for i in range(len(job_order) - 1):\n            job1 = job_order[i]\n            job2 = job_order[i + 1]\n            # Better solutions deposit more pheromones\n            deposit = 1.0 / (makespan + 1e-6)\n            self.pheromones[job1][job2] += deposit\n            self.pheromones[job2][job1] += deposit\n    \n    def solve_with_cp_sat(self):\n        \"\"\"Use CP-SAT to get a good initial solution for pheromone guidance\"\"\"\n        model = cp_model.CpModel()\n        \n        # Create variables\n        all_ops = []\n        for job_idx, job in enumerate(self.jobs):\n            for op_idx, op in enumerate(job):\n                machine = op['machine']\n                duration = op['duration']\n                \n                # Start time variable\n                start_var = model.NewIntVar(0, 10000, f'job_{job_idx}_op_{op_idx}_start')\n                all_ops.append((job_idx, op_idx, machine, duration, start_var))\n        \n        # Add constraints\n        # 1. Operation order within jobs\n        for job_idx, job in enumerate(self.jobs):\n            for op_idx in range(1, len(job)):\n                prev_op = all_ops[job_idx * len(job) + op_idx - 1]\n                curr_op = all_ops[job_idx * len(job) + op_idx]\n                model.Add(curr_op[4] >= prev_op[4] + prev_op[3])\n        \n        # 2. Machine capacity constraints\n        for machine in range(self.n_machines):\n            machine_ops = [op for op in all_ops if op[2] == machine]\n            for i in range(len(machine_ops)):\n                for j in range(i + 1, len(machine_ops)):\n                    op1 = machine_ops[i]\n                    op2 = machine_ops[j]\n                    \n                    # Create interval variables\n                    interval1 = model.NewIntervalVar(op1[4], op1[3], op2[4], f'machine_{machine}_op1_{i}')\n                    interval2 = model.NewIntervalVar(op2[4], op2[3], op1[4], f'machine_{machine}_op2_{j}')\n                    \n                    # Add no-overlap constraint\n                    model.AddNoOverlap([interval1, interval2])\n        \n        # Objective: minimize makespan\n        makespan = model.NewIntVar(0, 10000, 'makespan')\n        for op in all_ops:\n            model.Add(makespan >= op[4] + op[3])\n        model.Minimize(makespan)\n        \n        # Solve\n        solver = cp_model.CpSolver()\n        solver.parameters.max_time_in_seconds = 5.0  # Limit CP-SAT time\n        status = solver.Solve(model)\n        \n        if status == cp_model.OPTIMAL or status == cp_model.FEASIBLE:\n            # Build schedule from solution\n            scheduled_jobs = []\n            for job_idx, job in enumerate(self.jobs):\n                scheduled_ops = []\n                for op_idx, op in enumerate(job):\n                    op_copy = op.copy()\n                    start_val = solver.Value(all_ops[job_idx * len(job) + op_idx][4])\n                    op_copy['start'] = start_val\n                    scheduled_ops.append(op_copy)\n                scheduled_jobs.append(scheduled_ops)\n            \n            makespan_val = solver.Value(makespan)\n            return scheduled_jobs, makespan_val\n        \n        return None, float('inf')\n    \n    def run(self):\n        \"\"\"Run the ACO algorithm\"\"\"\n        # First try to get a good solution from CP-SAT\n        cp_schedule, cp_makespan = self.solve_with_cp_sat()\n        if cp_schedule is not None:\n            self.best_schedule = cp_schedule\n            self.best_makespan = cp_makespan\n            # Initialize pheromones based on CP-SAT solution\n            self._update_pheromones(cp_schedule, cp_makespan)\n        \n        # ACO main loop\n        start_time = time.time()\n        while (time.time() - start_time) < 0.8 * TIMEOUT_SEC:\n            # Construct solutions\n            for _ in range(self.n_ants):\n                job_order = self._construct_schedule()\n                schedule, makespan = self._schedule_from_order(job_order)\n                \n                # Apply local repair\n                repaired_schedule = self._local_repair(schedule)\n                repaired_makespan = self._calculate_makespan(repaired_schedule)\n                \n                # Update best solution\n                if repaired_makespan < self.best_makespan:\n                    self.best_schedule = repaired_schedule\n                    self.best_makespan = repaired_makespan\n            \n            # Update pheromones\n            if self.best_schedule is not None:\n                self._update_pheromones(self.best_schedule, self.best_makespan)\n        \n        return self.best_schedule if self.best_schedule is not None else self._schedule_from_order(list(range(self.n_jobs)))[0]\n\ndef solve(jobs: list[list[dict]]) -> list[list[dict]]:\n    \"\"\"Solve the job shop scheduling problem using ACO with CP-SAT guidance\"\"\"\n    scheduler = AntColonyScheduler(jobs)\n    return scheduler.run()"
