    direction: "Implement Adaptive Large Neighborhood Search (ALNS) with machine‑based removal: randomly select a subset of operations on the most loaded machines, re‑optimise them using a fast CP‑SAT sub‑model, and adapt removal probabilities based on observed improvement."
    source_refs[0]:
    approach: Fixed ALNS with CP-SAT reoptimization ensuring all operations are included
    code: "import time\nimport random\nfrom collections import defaultdict\nfrom ortools.sat.python import cp_model\n\nTIMEOUT_SEC = 120\n_START_TIME = time.time()\n\ndef solve(jobs: list[list[dict]]) -> list[list[dict]]:\n    \"\"\"\n    Solve the Job Shop Scheduling Problem using Adaptive Large Neighborhood Search (ALNS)\n    with machine-based removal and CP-SAT sub-model re-optimization.\n    \"\"\"\n    \n    # Initialize best solution with a simple greedy dispatch\n    best_solution = greedy_dispatch(jobs)\n    best_makespan = compute_makespan(best_solution)\n    \n    # ALNS parameters\n    max_iterations = 1000\n    removal_weights = {m: 1.0 for m in ['random', 'worst_machine', 'longest_duration']}\n    removal_methods = ['random', 'worst_machine', 'longest_duration']\n    \n    # Track improvement history\n    improvement_history = []\n    \n    for iteration in range(max_iterations):\n        # Check timeout\n        elapsed = time.time() - _START_TIME\n        if elapsed > 0.8 * TIMEOUT_SEC:\n            break\n        \n        # Select removal method based on weights\n        weights = [removal_weights[m] for m in removal_methods]\n        if sum(weights) == 0:\n            weights = [1.0] * len(removal_methods)\n        method = random.choices(removal_methods, weights=weights, k=1)[0]\n        \n        # Apply removal\n        removed_ops, remaining_solution = remove_operations(best_solution, method)\n        \n        # Re-optimize using CP-SAT sub-model\n        reoptimized_solution = reoptimize_with_cpsat(remaining_solution, removed_ops, jobs)\n        \n        # Evaluate new solution\n        current_makespan = compute_makespan(reoptimized_solution)\n        \n        # Update best solution if improved\n        if current_makespan < best_makespan:\n            best_solution = reoptimized_solution\n            best_makespan = current_makespan\n            improvement_history.append(1)  # Record improvement\n        else:\n            improvement_history.append(0)\n        \n        # Adapt removal weights based on recent performance\n        if len(improvement_history) >= 10:\n            recent_improvements = sum(improvement_history[-10:])\n            if recent_improvements > 5:  # If recent improvements are good\n                removal_weights[method] *= 1.1\n            else:\n                removal_weights[method] *= 0.9\n    \n    return best_solution\n\ndef greedy_dispatch(jobs: list[list[dict]]) -> list[list[dict]]:\n    \"\"\"\n    Generate an initial solution using a greedy dispatch rule.\n    \"\"\"\n    solution = []\n    machine_availability = defaultdict(int)\n    \n    for job in jobs:\n        scheduled_ops = []\n        prev_end = 0\n        \n        for op in job:\n            machine = op['machine']\n            duration = op['duration']\n            \n            # Start time is max of previous operation end or machine availability\n            start = max(prev_end, machine_availability[machine])\n            \n            scheduled_ops.append({\n                'machine': machine,\n                'duration': duration,\n                'start': start\n            })\n            \n            # Update machine availability and previous operation end\n            machine_availability[machine] = start + duration\n            prev_end = start + duration\n        \n        solution.append(scheduled_ops)\n    \n    return solution\n\ndef compute_makespan(solution: list[list[dict]]) -> int:\n    \"\"\"\n    Compute the makespan (total completion time) of a solution.\n    \"\"\"\n    makespan = 0\n    for job in solution:\n        for op in job:\n            end_time = op['start'] + op['duration']\n            if end_time > makespan:\n                makespan = end_time\n    return makespan\n\ndef remove_operations(solution: list[list[dict]], method: str):\n    \"\"\"\n    Remove operations based on the specified method.\n    Returns: (removed_ops, remaining_solution)\n    \"\"\"\n    removed_ops = []\n    remaining_solution = [[] for _ in solution]\n    \n    if method == 'random':\n        # Randomly remove 20% of operations\n        total_ops = sum(len(job) for job in solution)\n        num_to_remove = max(1, int(0.2 * total_ops))\n        \n        # Flatten all operations with their job and position\n        all_ops = []\n        for job_idx, job in enumerate(solution):\n            for op_idx, op in enumerate(job):\n                all_ops.append((job_idx, op_idx, op))\n        \n        # Randomly select operations to remove\n        removed_indices = set(random.sample(range(len(all_ops)), min(num_to_remove, len(all_ops))))\n        \n        # Build remaining solution and collect removed ops\n        for flat_idx, (job_idx, op_idx, op) in enumerate(all_ops):\n            if flat_idx not in removed_indices:\n                remaining_solution[job_idx].append(op)\n            else:\n                removed_ops.append((job_idx, op_idx, op))\n    \n    elif method == 'worst_machine':\n        # Remove operations from the most loaded machine\n        machine_loads = defaultdict(int)\n        \n        # Calculate machine loads\n        for job in solution:\n            for op in job:\n                machine_loads[op['machine']] += op['duration']\n        \n        if machine_loads:\n            worst_machine = max(machine_loads.items(), key=lambda x: x[1])[0]\n            \n            # Remove 30% of operations on this machine\n            ops_on_machine = []\n            for job_idx, job in enumerate(solution):\n                for op_idx, op in enumerate(job):\n                    if op['machine'] == worst_machine:\n                        ops_on_machine.append((job_idx, op_idx, op))\n            \n            num_to_remove = max(1, int(0.3 * len(ops_on_machine)))\n            removed_indices = set(random.sample(range(len(ops_on_machine)), min(num_to_remove, len(ops_on_machine))))\n            \n            # Build remaining solution\n            for idx, (job_idx, op_idx, op) in enumerate(ops_on_machine):\n                if idx not in removed_indices:\n                    remaining_solution[job_idx].append(op)\n                else:\n                    removed_ops.append((job_idx, op_idx, op))\n            \n            # Add operations not on worst machine\n            for job_idx, job in enumerate(solution):\n                for op_idx, op in enumerate(job):\n                    if op['machine'] != worst_machine:\n                        remaining_solution[job_idx].append(op)\n    \n    elif method == 'longest_duration':\n        # Remove operations with longest durations\n        all_ops = []\n        for job_idx, job in enumerate(solution):\n            for op_idx, op in enumerate(job):\n                all_ops.append((job_idx, op_idx, op))\n        \n        # Sort by duration descending\n        all_ops.sort(key=lambda x: x[2]['duration'], reverse=True)\n        \n        num_to_remove = max(1, int(0.15 * len(all_ops)))\n        removed_indices = set(random.sample(range(num_to_remove), min(num_to_remove, len(all_ops))))\n        \n        # Build remaining solution\n        for idx, (job_idx, op_idx, op) in enumerate(all_ops):\n            if idx not in removed_indices:\n                remaining_solution[job_idx].append(op)\n            else:\n                removed_ops.append((job_idx, op_idx, op))\n    \n    return removed_ops, remaining_solution\n\ndef reoptimize_with_cpsat(remaining_solution: list[list[dict]], removed_ops: list, original_jobs: list[list[dict]]) -> list[list[dict]]:\n    \"\"\"\n    Re-optimize the solution using a CP-SAT sub-model for the removed operations.\n    \"\"\"\n    model = cp_model.CpModel()\n    \n    # Create a complete operation list maintaining job order\n    all_ops = []\n    for job_idx, job in enumerate(original_jobs):\n        # Get operations from remaining solution\n        remaining_in_job = [op for op in remaining_solution[job_idx] if 'start' in op]\n        # Get removed operations for this job\n        removed_in_job = [op for op in removed_ops if op[0] == job_idx]\n        \n        # Merge operations maintaining order\n        merged_ops = []\n        remaining_ptr = 0\n        removed_ptr = 0\n        \n        for original_op in original_jobs[job_idx]:\n            # Check if this operation is in remaining solution\n            if remaining_ptr < len(remaining_in_job) and remaining_in_job[remaining_ptr]['machine'] == original_op['machine']:\n                merged_ops.append((job_idx, len(merged_ops), remaining_in_job[remaining_ptr]))\n                remaining_ptr += 1\n            # Check if this operation is in removed ops\n            elif removed_ptr < len(removed_in_job) and removed_in_job[removed_ptr][2]['machine'] == original_op['machine']:\n                merged_ops.append((job_idx, len(merged_ops), removed_in_job[removed_ptr][2]))\n                removed_ptr += 1\n        \n        all_ops.extend(merged_ops)\n    \n    # Create variables\n    start_vars = {}\n    for job_idx, op_idx, op in all_ops:\n        start_vars[(job_idx, op_idx)] = model.NewIntVar(0, 10000, f'start_{job_idx}_{op_idx}')\n    \n    # Add constraints\n    # 1. Precedence constraints within jobs\n    for job_idx in range(len(original_jobs)):\n        job_ops = [op for op in all_ops if op[0] == job_idx]\n        job_ops.sort(key=lambda x: x[1])\n        \n        for i in range(len(job_ops) - 1):\n            curr_op = job_ops[i]\n            next_op = job_ops[i + 1]\n            \n            model.Add(start_vars[(curr_op[0], curr_op[1])] + curr_op[2]['duration'] <= \n                     start_vars[(next_op[0], next_op[1])])\n    \n    # 2. Machine capacity constraints\n    machine_ops = defaultdict(list)\n    for job_idx, op_idx, op in all_ops:\n        machine_ops[op['machine']].append((job_idx, op_idx, op))\n    \n    for machine, ops in machine_ops.items():\n        for i in range(len(ops)):\n            for j in range(i + 1, len(ops)):\n                op1 = ops[i]\n                op2 = ops[j]\n                \n                # Either op1 comes before op2 or vice versa\n                model.Add(start_vars[(op1[0], op1[1])] + op1[2]['duration'] <= start_vars[(op2[0], op2[1])]).OnlyEnforceIf(\n                    model.NewBoolVar(f'op1_before_op2_{op1[0]}_{op1[1]}_{op2[0]}_{op2[1]}'))\n                model.Add(start_vars[(op2[0], op2[1])] + op2[2]['duration'] <= start_vars[(op1[0], op1[1])]).OnlyEnforceIf(\n                    model.NewBoolVar(f'op2_before_op1_{op1[0]}_{op1[1]}_{op2[0]}_{op2[1]}'))\n    \n    # Objective: minimize makespan\n    makespan = model.NewIntVar(0, 10000, 'makespan')\n    for job_idx, op_idx, op in all_ops:\n        model.Add(start_vars[(job_idx, op_idx)] + op['duration'] <= makespan)\n    model.Minimize(makespan)\n    \n    # Solve\n    solver = cp_model.CpSolver()\n    solver.parameters.max_time_in_seconds = 5.0  # Limit solving time\n    status = solver.Solve(model)\n    \n    # Build solution\n    solution = [[] for _ in original_jobs]\n    for job_idx, op_idx, op in all_ops:\n        start_time = solver.Value(start_vars[(job_idx, op_idx)])\n        solution[job_idx].append({\n            'machine': op['machine'],\n            'duration': op['duration'],\n            'start': start_time\n        })\n    \n    return solution"
