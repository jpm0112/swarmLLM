    approach: Hybrid Simulated Annealing starting from CP-SAT solution with critical path-focused swaps
    code: "from ortools.sat.python import cp_model\nimport time\nimport random\nimport math\n\ndef solve(jobs: list[list[dict]]) -> list[list[dict]]:\n    # Extract problem data\n    num_jobs = len(jobs)\n    num_machines = max(max(op['machine'] for op in job) for job in jobs) + 1\n    \n    # First, get a good initial solution using CP-SAT\n    cp_solution = solve_with_cp(jobs, num_jobs, num_machines)\n    \n    # If CP-SAT fails or times out, return the partial solution\n    if cp_solution is None:\n        return fallback_greedy(jobs)\n    \n    # Use Simulated Annealing to improve the CP-SAT solution\n    best_solution = simulated_annealing(jobs, cp_solution)\n    \n    return best_solution\n\ndef solve_with_cp(jobs, num_jobs, num_machines):\n    try:\n        model = cp_model.CpModel()\n        \n        # Create variables\n        all_ops = []\n        for job_idx, job in enumerate(jobs):\n            for op_idx, op in enumerate(job):\n                start_var = model.NewIntVar(0, 1000000, f'start_{job_idx}_{op_idx}')\n                duration = op['duration']\n                end_var = model.NewIntVar(0, 1000000, f'end_{job_idx}_{op_idx}')\n                model.Add(end_var == start_var + duration)\n                \n                all_ops.append({\n                    'job': job_idx,\n                    'op': op_idx,\n                    'machine': op['machine'],\n                    'start': start_var,\n                    'end': end_var,\n                    'duration': duration\n                })\n        \n        # Precedence constraints\n        for job_idx, job in enumerate(jobs):\n            for op_idx in range(1, len(job)):\n                prev_op = all_ops[job_idx * len(job) + op_idx - 1]\n                curr_op = all_ops[job_idx * len(job) + op_idx]\n                model.Add(curr_op['start'] >= prev_op['end'])\n        \n        # Machine capacity constraints\n        for machine in range(num_machines):\n            machine_ops = [op for op in all_ops if op['machine'] == machine]\n            if machine_ops:\n                intervals = []\n                for op in machine_ops:\n                    interval = model.NewIntervalVar(op['start'], op['duration'], op['end'], \n                                                   f'interval_{op[\"job\"]}_{op[\"op\"]}')\n                    intervals.append(interval)\n                model.AddNoOverlap(intervals)\n        \n        # Objective: minimize makespan\n        makespan = model.NewIntVar(0, 1000000, 'makespan')\n        model.AddMaxEquality(makespan, [op['end'] for op in all_ops])\n        model.Minimize(makespan)\n        \n        # Solve with time limit\n        solver = cp_model.CpSolver()\n        remaining_time = TIMEOUT_SEC - (time.time() - _START_TIME)\n        solver.parameters.max_time_in_seconds = 0.3 * remaining_time  # Use 30% of time for CP\n        \n        status = solver.Solve(model)\n        \n        if status in (cp_model.OPTIMAL, cp_model.FEASIBLE):\n            solution = []\n            for job_idx, job in enumerate(jobs):\n                scheduled_job = []\n                for op_idx, op in enumerate(job):\n                    op_start = solver.Value(all_ops[job_idx * len(job) + op_idx]['start'])\n                    scheduled_op = {\n                        'machine': op['machine'],\n                        'duration': op['duration'],\n                        'start': op_start\n                    }\n                    scheduled_job.append(scheduled_op)\n                solution.append(scheduled_job)\n            return solution\n    except Exception as e:\n        pass\n    return None\n\ndef fallback_greedy(jobs):\n    num_machines = max(max(op['machine'] for op in job) for job in jobs) + 1\n    solution = []\n    machine_avail = [0] * num_machines\n    job_start = [0] * len(jobs)\n    \n    for job_idx, job in enumerate(jobs):\n        job_ops = []\n        for op in job:\n            m = op['machine']\n            start_time = max(job_start[job_idx], machine_avail[m])\n            job_ops.append({\n                'machine': m,\n                'duration': op['duration'],\n                'start': start_time\n            })\n            job_start[job_idx] = start_time + op['duration']\n            machine_avail[m] = start_time + op['duration']\n        solution.append(job_ops)\n    return solution\n\ndef simulated_annealing(jobs, initial_solution):\n    current_solution = [op.copy() for job in initial_solution for op in job]\n    best_solution = [op.copy() for op in current_solution]\n    current_makespan = compute_makespan(current_solution)\n    best_makespan = current_makespan\n    \n    # Parameters\n    initial_temp = 1000\n    final_temp = 1\n    cooling_rate = 0.995\n    current_temp = initial_temp\n    \n    start_time = time.time()\n    \n    while current_temp > final_temp:\n        # Check time limit\n        if time.time() - start_time > 0.65 * TIMEOUT_SEC:\n            break\n        \n        # Generate neighbor by swapping operations on critical path\n        neighbor = generate_neighbor(current_solution, jobs)\n        neighbor_makespan = compute_makespan(neighbor)\n        \n        # Acceptance probability\n        delta = neighbor_makespan - current_makespan\n        if delta < 0 or random.random() < math.exp(-delta / current_temp):\n            current_solution = neighbor\n            current_makespan = neighbor_makespan\n            \n            if current_makespan < best_makespan:\n                best_solution = [op.copy() for op in current_solution]\n                best_makespan = current_makespan\n        \n        current_temp *= cooling_rate\n    \n    # Reconstruct job structure\n    solution = []\n    op_index = 0\n    for job in jobs:\n        scheduled_job = []\n        for _ in job:\n            scheduled_job.append(best_solution[op_index])\n            op_index += 1\n        solution.append(scheduled_job)\n    \n    return solution\n\ndef generate_neighbor(solution, jobs):\n    # Find critical path operations\n    critical_ops = find_critical_path(solution)\n    \n    if len(critical_ops) < 2:\n        return solution\n    \n    # Select two random operations on critical path from different jobs\n    while True:\n        i, j = random.sample(range(len(critical_ops)), 2)\n        op1 = critical_ops[i]\n        op2 = critical_ops[j]\n        \n        # Check if they can be swapped (same machine and different jobs)\n        if op1['machine'] == op2['machine'] and op1['job'] != op2['job']:\n            # Check if swapping maintains precedence constraints\n            if can_swap(solution, op1, op2):\n                new_solution = [op.copy() for op in solution]\n                \n                # Swap the operations\n                idx1 = solution.index(op1)\n                idx2 = solution.index(op2)\n                new_solution[idx1], new_solution[idx2] = new_solution[idx2], new_solution[idx1]\n                \n                # Recompute start times for affected operations\n                new_solution = recompute_start_times(new_solution, jobs)\n                \n                return new_solution\n\ndef find_critical_path(solution):\n    # Find operations on the critical path (those that determine makespan)\n    makespan = max(op['start'] + op['duration'] for op in solution)\n    critical_ops = [op for op in solution if op['start'] + op['duration'] == makespan]\n    \n    # If multiple operations finish at makespan, pick one path\n    if critical_ops:\n        return [critical_ops[0]]\n    \n    return []\n\ndef can_swap(solution, op1, op2):\n    # Check if swapping maintains precedence constraints within jobs\n    job1_ops = [op for op in solution if op['job'] == op1['job']]\n    job2_ops = [op for op in solution if op['job'] == op2['job']]\n    \n    # Find positions in their respective jobs\n    pos1_in_job = job1_ops.index(op1)\n    pos2_in_job = job2_ops.index(op2)\n    \n    # Check if op1 is the last operation in its job or op2 comes after op1's successor\n    if pos1_in_job < len(job1_ops) - 1:\n        next_op1 = job1_ops[pos1_in_job + 1]\n        if next_op1['start'] < op2['start'] + op2['duration']:\n            return False\n    \n    # Check if op2 is the last operation in its job or op1 comes after op2's successor\n    if pos2_in_job < len(job2_ops) - 1:\n        next_op2 = job2_ops[pos2_in_job + 1]\n        if next_op2['start'] < op1['start'] + op1['duration']:\n            return False\n    \n    return True\n\ndef recompute_start_times(solution, jobs):\n    # Recompute start times while maintaining feasibility\n    num_jobs = len(jobs)\n    num_machines = max(op['machine'] for op in solution) + 1\n    \n    # Initialize machine availability\n    machine_avail = [0] * num_machines\n    \n    # Process operations in order of their start times\n    sorted_ops = sorted(solution, key=lambda x: x['start'])\n    \n    for op in sorted_ops:\n        m = op['machine']\n        # Start time is max of machine availability and job's previous operation completion\n        job_ops = [o for o in solution if o['job'] == op['job']]\n        pos_in_job = job_ops.index(op)\n        \n        if pos_in_job == 0:\n            prev_completion = 0\n        else:\n            prev_op = job_ops[pos_in_job - 1]\n            prev_completion = prev_op['start'] + prev_op['duration']\n        \n        op['start'] = max(prev_completion, machine_avail[m])\n        machine_avail[m] = op['start'] + op['duration']\n    \n    return solution\n\ndef compute_makespan(solution):\n    return max(op['start'] + op['duration'] for op in solution)"
