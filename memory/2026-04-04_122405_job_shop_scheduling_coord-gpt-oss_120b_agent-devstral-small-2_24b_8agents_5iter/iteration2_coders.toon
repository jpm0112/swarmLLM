    approach: Fixed reinforcement learning approach with proper precedence constraints
    code: "import numpy as np\nimport time\nfrom collections import defaultdict\n\n# Predefined globals for timeout handling\nTIMEOUT_SEC = 30\n_START_TIME = time.time()\n\nclass JobShopEnvironment:\n    def __init__(self, jobs):\n        self.jobs = jobs\n        self.num_jobs = len(jobs)\n        self.num_machines = max(max(op['machine'] for op in job) for job in jobs) + 1\n        self.reset()\n    \n    def reset(self):\n        self.time = 0\n        self.completed_ops = [0] * self.num_jobs\n        self.machine_available = [0] * self.num_machines\n        self.schedule = [ [{'machine': op['machine'], 'duration': op['duration'], 'start': 0} for op in job] for job in self.jobs ]\n        self.done = False\n        return self._get_state()\n    \n    def _get_state(self):\n        # State representation: [current_time, machine_availabilities, job_progress]\n        state = [self.time / 100.0]  # Normalize time\n        state.extend([avail / 100.0 for avail in self.machine_available])  # Normalize machine times\n        state.extend([comp / len(self.jobs[j]) for j, comp in enumerate(self.completed_ops)])  # Normalize job progress\n        return np.array(state, dtype=np.float32)\n    \n    def step(self, action):\n        # Action is the job index to schedule next\n        job_idx = action\n        \n        if job_idx < 0 or job_idx >= self.num_jobs:\n            return self._get_state(), -100, self.done, {}\n        \n        if self.completed_ops[job_idx] >= len(self.jobs[job_idx]):\n            return self._get_state(), -50, self.done, {}\n        \n        op = self.jobs[job_idx][self.completed_ops[job_idx]]\n        machine = op['machine']\n        duration = op['duration']\n        \n        # Calculate earliest start time\n        prev_op_finish = self.schedule[job_idx][self.completed_ops[job_idx]-1]['start'] + self.schedule[job_idx][self.completed_ops[job_idx]-1]['duration'] if self.completed_ops[job_idx] > 0 else 0\n        machine_ready = self.machine_available[machine]\n        start_time = max(prev_op_finish, machine_ready)\n        \n        # Update schedule\n        self.schedule[job_idx][self.completed_ops[job_idx]]['start'] = start_time\n        \n        # Update state\n        self.completed_ops[job_idx] += 1\n        self.machine_available[machine] = start_time + duration\n        self.time = max(self.time, start_time + duration)\n        \n        # Check if all jobs are done\n        self.done = all(comp == len(self.jobs[j]) for j, comp in enumerate(self.completed_ops))\n        \n        # Reward: negative makespan (we want to minimize)\n        reward = -self.time / 100.0\n        \n        return self._get_state(), reward, self.done, {}\n    \n    def get_makespan(self):\n        return max(op['start'] + op['duration'] for job in self.schedule for op in job)\n\nclass PolicyNetwork:\n    def __init__(self, state_size, action_size):\n        self.state_size = state_size\n        self.action_size = action_size\n        \n        # Simple neural network parameters\n        self.W1 = np.random.randn(state_size, 16) * 0.1\n        self.b1 = np.zeros(16)\n        self.W2 = np.random.randn(16, action_size) * 0.1\n        self.b2 = np.zeros(action_size)\n        \n        self.learning_rate = 0.01\n    \n    def forward(self, state):\n        # Single hidden layer neural network\n        h = np.tanh(np.dot(state, self.W1) + self.b1)\n        logits = np.dot(h, self.W2) + self.b2\n        probs = self.softmax(logits)\n        return probs\n    \n    def softmax(self, x):\n        e_x = np.exp(x - np.max(x))\n        return e_x / e_x.sum()\n    \n    def update(self, states, actions, rewards):\n        # Policy gradient update\n        for state, action, reward in zip(states, actions, rewards):\n            probs = self.forward(state)\n            dsoftmax = probs.copy()\n            dsoftmax[action] -= 1\n            \n            # Backpropagate\n            h = np.tanh(np.dot(state, self.W1) + self.b1)\n            dh = (1 - h**2) * np.dot(dsoftmax, self.W2.T)\n            \n            self.W2 -= self.learning_rate * np.outer(h, dsoftmax) * reward\n            self.b2 -= self.learning_rate * dsoftmax * reward\n            self.W1 -= self.learning_rate * np.outer(state, dh) * reward\n            self.b1 -= self.learning_rate * dh * reward\n\ndef greedy_schedule(jobs):\n    \"\"\"Fallback greedy heuristic: schedule operations as soon as possible\"\"\"\n    num_jobs = len(jobs)\n    num_machines = max(max(op['machine'] for op in job) for job in jobs) + 1\n    \n    # Initialize\n    machine_available = [0] * num_machines\n    job_progress = [0] * num_jobs\n    schedule = [ [{'machine': op['machine'], 'duration': op['duration'], 'start': 0} for op in job] for job in jobs ]\n    \n    while True:\n        scheduled = False\n        for job_idx in range(num_jobs):\n            if job_progress[job_idx] >= len(jobs[job_idx]):\n                continue\n            \n            op = jobs[job_idx][job_progress[job_idx]]\n            machine = op['machine']\n            duration = op['duration']\n            \n            # Calculate earliest start time\n            prev_op_finish = schedule[job_idx][job_progress[job_idx]-1]['start'] + schedule[job_idx][job_progress[job_idx]-1]['duration'] if job_progress[job_idx] > 0 else 0\n            machine_ready = machine_available[machine]\n            start_time = max(prev_op_finish, machine_ready)\n            \n            # Schedule this operation\n            schedule[job_idx][job_progress[job_idx]]['start'] = start_time\n            machine_available[machine] = start_time + duration\n            job_progress[job_idx] += 1\n            scheduled = True\n        \n        if not scheduled:\n            break\n    \n    return schedule\n\ndef solve(jobs):\n    if not jobs:\n        return []\n    \n    # Initialize environment\n    env = JobShopEnvironment(jobs)\n    state_size = 1 + env.num_machines + env.num_jobs\n    action_size = env.num_jobs\n    \n    # Initialize policy network\n    policy = PolicyNetwork(state_size, action_size)\n    \n    best_schedule = None\n    best_makespan = float('inf')\n    \n    # Training loop with timeout check\n    start_time = time.time()\n    num_episodes = 0\n    \n    while (time.time() - start_time) < 0.8 * TIMEOUT_SEC:\n        num_episodes += 1\n        state = env.reset()\n        done = False\n        episode_states = []\n        episode_actions = []\n        episode_rewards = []\n        \n        while not done and (time.time() - start_time) < 0.8 * TIMEOUT_SEC:\n            # Get action probabilities\n            probs = policy.forward(state)\n            action = np.random.choice(action_size, p=probs)\n            \n            # Take action\n            next_state, reward, done, _ = env.step(action)\n            \n            # Store experience\n            episode_states.append(state)\n            episode_actions.append(action)\n            episode_rewards.append(reward)\n            \n            state = next_state\n        \n        # Update policy\n        policy.update(episode_states, episode_actions, episode_rewards)\n        \n        # Check if this is the best schedule so far\n        current_makespan = env.get_makespan()\n        if current_makespan < best_makespan:\n            best_makespan = current_makespan\n            best_schedule = [ [{'machine': op['machine'], 'duration': op['duration'], 'start': op['start']} for op in job] for job in env.schedule ]\n    \n    # If we didn't find any solution with RL, fall back to greedy\n    if best_schedule is None or best_makespan == float('inf'):\n        return greedy_schedule(jobs)\n    \n    return best_schedule"
