    direction: "Re‑implement tabu search using the CP‑SAT schedule as the initial solution and a richer neighborhood (swap any two operations on the critical path, not only adjacent). Maintain a dynamic tabu tenure based on recent improvement magnitude."
    source_refs[1,]{agent_id,iteration}:
      4,1
    approach: Tabu search with CP-SAT initial solution and dynamic tenure
    code: "from ortools.sat.python import cp_model\nimport time\nimport random\nimport numpy as np\n\ndef solve(jobs: list[list[dict]]) -> list[list[dict]]:\n    # Extract problem data\n    num_jobs = len(jobs)\n    num_machines = max(max(op['machine'] for op in job) for job in jobs) + 1\n    \n    # Step 1: Get initial solution using CP-SAT\n    def get_cp_solution():\n        model = cp_model.CpModel()\n        all_ops = []\n        for job_idx, job in enumerate(jobs):\n            for op_idx, op in enumerate(job):\n                start_var = model.NewIntVar(0, 1000000, f'start_{job_idx}_{op_idx}')\n                duration = op['duration']\n                end_var = model.NewIntVar(0, 1000000, f'end_{job_idx}_{op_idx}')\n                model.Add(end_var == start_var + duration)\n                all_ops.append({\n                    'job': job_idx,\n                    'op': op_idx,\n                    'machine': op['machine'],\n                    'start': start_var,\n                    'end': end_var,\n                    'duration': duration\n                })\n        \n        # Precedence constraints\n        for job_idx, job in enumerate(jobs):\n            for op_idx in range(1, len(job)):\n                prev_op = all_ops[job_idx * len(job) + op_idx - 1]\n                curr_op = all_ops[job_idx * len(job) + op_idx]\n                model.Add(curr_op['start'] >= prev_op['end'])\n        \n        # Machine constraints\n        for machine in range(num_machines):\n            machine_ops = [op for op in all_ops if op['machine'] == machine]\n            if machine_ops:\n                intervals = []\n                for op in machine_ops:\n                    interval = model.NewIntervalVar(op['start'], op['duration'], op['end'], f'interval_{op[\"job\"]}_{op[\"op\"]}')\n                    intervals.append(interval)\n                model.AddNoOverlap(intervals)\n        \n        makespan = model.NewIntVar(0, 1000000, 'makespan')\n        model.AddMaxEquality(makespan, [op['end'] for op in all_ops])\n        model.Minimize(makespan)\n        \n        solver = cp_model.CpSolver()\n        remaining_time = TIMEOUT_SEC - (time.time() - _START_TIME)\n        solver.parameters.max_time_in_seconds = 0.1 * remaining_time\n        status = solver.Solve(model)\n        \n        solution = []\n        for job_idx, job in enumerate(jobs):\n            scheduled_job = []\n            for op_idx, op in enumerate(job):\n                op_start = solver.Value(all_ops[job_idx * len(job) + op_idx]['start'])\n                scheduled_op = {\n                    'machine': op['machine'],\n                    'duration': op['duration'],\n                    'start': op_start\n                }\n                scheduled_job.append(scheduled_op)\n            solution.append(scheduled_job)\n        return solution\n    \n    current_solution = get_cp_solution()\n    current_makespan = max(op['start'] + op['duration'] for job in current_solution for op in job)\n    \n    # Step 2: Tabu search setup\n    best_solution = [job.copy() for job in current_solution]\n    best_makespan = current_makespan\n    \n    tabu_list = {}\n    tabu_tenure = 5\n    min_tenure = 3\n    max_tenure = 15\n    \n    # Helper functions\n    def get_critical_path(solution):\n        # Identify operations on the critical path (longest path from start to end)\n        # Simplified: operations that finish at makespan\n        makespan = max(op['start'] + op['duration'] for job in solution for op in job)\n        critical_ops = []\n        for job_idx, job in enumerate(solution):\n            for op_idx, op in enumerate(job):\n                if op['start'] + op['duration'] == makespan:\n                    critical_ops.append((job_idx, op_idx))\n        return critical_ops\n    \n    def swap_operations(solution, op1, op2):\n        # Swap two operations within their jobs\n        job1, op_idx1 = op1\n        job2, op_idx2 = op2\n        if job1 == job2:\n            # Same job: swap operations\n            new_solution = [job.copy() for job in solution]\n            new_solution[job1][op_idx1], new_solution[job1][op_idx2] = new_solution[job1][op_idx2], new_solution[job1][op_idx1]\n        else:\n            # Different jobs: swap entire operations (machine and duration)\n            new_solution = [job.copy() for job in solution]\n            op1_data = new_solution[job1][op_idx1].copy()\n            op2_data = new_solution[job2][op_idx2].copy()\n            new_solution[job1][op_idx1] = op2_data\n            new_solution[job2][op_idx2] = op1_data\n        return new_solution\n    \n    def evaluate_solution(solution):\n        # Check feasibility and calculate makespan\n        # Check precedence constraints\n        for job in solution:\n            for i in range(1, len(job)):\n                if job[i]['start'] < job[i-1]['start'] + job[i-1]['duration']:\n                    return float('inf')\n        \n        # Check machine constraints\n        machine_usage = {m: [] for m in range(num_machines)}\n        for job in solution:\n            for op in job:\n                machine_usage[op['machine']].append((op['start'], op['start'] + op['duration']))\n        \n        for machine in machine_usage:\n            intervals = sorted(machine_usage[machine])\n            for i in range(1, len(intervals)):\n                if intervals[i][0] < intervals[i-1][1]:\n                    return float('inf')\n        \n        return max(op['start'] + op['duration'] for job in solution for op in job)\n    \n    def reschedule(solution):\n        # Reschedule operations to earliest possible start time\n        # First, sort all operations by their earliest possible start time\n        all_ops = []\n        for job_idx, job in enumerate(solution):\n            for op_idx, op in enumerate(job):\n                all_ops.append({\n                    'job': job_idx,\n                    'op': op_idx,\n                    'machine': op['machine'],\n                    'duration': op['duration'],\n                    'earliest_start': 0\n                })\n        \n        # Calculate earliest start time for each operation\n        for job_idx, job in enumerate(solution):\n            for op_idx in range(len(job)):\n                if op_idx == 0:\n                    all_ops[job_idx * len(job) + op_idx]['earliest_start'] = 0\n                else:\n                    prev_op = all_ops[job_idx * len(job) + op_idx - 1]\n                    all_ops[job_idx * len(job) + op_idx]['earliest_start'] = prev_op['earliest_start'] + prev_op['duration']\n        \n        # Sort operations by earliest start time\n        all_ops.sort(key=lambda x: x['earliest_start'])\n        \n        # Schedule operations\n        machine_availability = {m: 0 for m in range(num_machines)}\n        job_completion = {j: 0 for j in range(num_jobs)}\n        \n        for op in all_ops:\n            job = op['job']\n            machine = op['machine']\n            duration = op['duration']\n            \n            # Earliest start is max of job completion and machine availability\n            start = max(job_completion[job], machine_availability[machine])\n            \n            # Update job completion and machine availability\n            job_completion[job] = start + duration\n            machine_availability[machine] = start + duration\n            \n            # Update solution\n            solution[job][op['op']]['start'] = start\n        \n        return solution\n    \n    # Main tabu search loop\n    start_time = time.time()\n    iteration = 0\n    \n    while time.time() - start_time < 0.8 * TIMEOUT_SEC:\n        iteration += 1\n        \n        # Get critical path operations\n        critical_ops = get_critical_path(current_solution)\n        if len(critical_ops) < 2:\n            break\n        \n        # Generate neighborhood: swap any two operations on critical path\n        neighborhood = []\n        for i in range(len(critical_ops)):\n            for j in range(i+1, len(critical_ops)):\n                op1 = critical_ops[i]\n                op2 = critical_ops[j]\n                \n                # Check if this swap is tabu\n                tabu_key = tuple(sorted((op1, op2)))\n                if tabu_key in tabu_list and tabu_list[tabu_key] > iteration:\n                    continue\n                \n                # Generate new solution\n                new_solution = swap_operations(current_solution, op1, op2)\n                new_solution = reschedule(new_solution)\n                new_makespan = evaluate_solution(new_solution)\n                \n                if new_makespan < float('inf'):\n                    neighborhood.append((new_solution, new_makespan, tabu_key))\n        \n        if not neighborhood:\n            break\n        \n        # Select best neighbor\n        neighborhood.sort(key=lambda x: x[1])\n        best_neighbor, best_neighbor_makespan, best_tabu_key = neighborhood[0]\n        \n        # Update tabu list and tenure\n        tabu_list[best_tabu_key] = iteration + tabu_tenure\n        \n        # Adjust tabu tenure based on improvement\n        if best_neighbor_makespan < best_makespan:\n            improvement = best_makespan - best_neighbor_makespan\n            tabu_tenure = max(min_tenure, min(max_tenure, tabu_tenure + int(improvement / 10)))\n        else:\n            tabu_tenure = max(min_tenure, tabu_tenure - 1)\n        \n        # Update current solution\n        current_solution = best_neighbor\n        current_makespan = best_neighbor_makespan\n        \n        # Update best solution\n        if current_makespan < best_makespan:\n            best_solution = [job.copy() for job in current_solution]\n            best_makespan = current_makespan\n    \n    return best_solution"
