    direction: Develop a memetic algorithm that combines a population‑based GA with a local search (2‑opt on operation sequences) and seeds the initial population with the CP‑SAT schedule to accelerate convergence.
    source_refs[0]:
    approach: Fixed memetic algorithm with CP-SAT initialization and 2-opt local search
    code: "import time\nimport random\nimport numpy as np\nfrom ortools.sat.python import cp_model\n\nTIMEOUT_SEC = 120\n_START_TIME = time.time()\n\ndef solve(jobs: list[list[dict]]) -> list[list[dict]]:\n    \"\"\"\n    Solves the Job Shop Scheduling Problem using a memetic algorithm that combines\n    a genetic algorithm with 2-opt local search, seeded with CP-SAT solutions.\n    \"\"\"\n    n_jobs = len(jobs)\n    n_machines = max(max(op['machine'] for op in job) for job in jobs) + 1\n    \n    # Extract machine sequences and durations for easier manipulation\n    machine_sequences = [[op['machine'] for op in job] for job in jobs]\n    durations = [[op['duration'] for op in job] for job in jobs]\n    \n    # Step 1: Generate initial population using CP-SAT solutions\n    def generate_cp_sat_solution():\n        model = cp_model.CpModel()\n        horizon = sum(sum(durations[j][i] for i in range(len(durations[j]))) for j in range(n_jobs))\n        \n        # Variables\n        starts = {}\n        for j in range(n_jobs):\n            for i in range(len(durations[j])):\n                starts[(j, i)] = model.NewIntVar(0, horizon, f'start_{j}_{i}')\n        \n        # Constraints\n        # Operation order within jobs\n        for j in range(n_jobs):\n            for i in range(1, len(durations[j])):\n                model.Add(starts[(j, i)] >= starts[(j, i-1)] + durations[j][i-1])\n        \n        # Machine capacity\n        for m in range(n_machines):\n            intervals = []\n            for j in range(n_jobs):\n                for i in range(len(durations[j])):\n                    if machine_sequences[j][i] == m:\n                        interval = model.NewIntervalVar(starts[(j, i)], durations[j][i], durations[j][i], f'interval_{j}_{i}_{m}')\n                        intervals.append(interval)\n            model.AddNoOverlap(intervals)\n        \n        # Objective: minimize makespan\n        makespan = model.NewIntVar(0, horizon, 'makespan')\n        for j in range(n_jobs):\n            last_op = len(durations[j]) - 1\n            model.Add(makespan >= starts[(j, last_op)] + durations[j][last_op])\n        model.Minimize(makespan)\n        \n        # Solve\n        solver = cp_model.CpSolver()\n        solver.parameters.max_time_in_seconds = 5.0\n        status = solver.Solve(model)\n        \n        if status == cp_model.OPTIMAL or status == cp_model.FEASIBLE:\n            solution = []\n            for j in range(n_jobs):\n                job_schedule = []\n                for i in range(len(durations[j])):\n                    start_time = solver.Value(starts[(j, i)])\n                    job_schedule.append({\n                        'machine': jobs[j][i]['machine'],\n                        'duration': jobs[j][i]['duration'],\n                        'start': start_time\n                    })\n                solution.append(job_schedule)\n            return solution\n        else:\n            # Fallback to random solution if CP-SAT fails\n            return generate_random_solution()\n    \n    def generate_random_solution():\n        solution = []\n        machine_timelines = [0] * n_machines\n        job_timelines = [0] * n_jobs\n        \n        for j in range(n_jobs):\n            job_schedule = []\n            for i in range(len(durations[j])):\n                m = jobs[j][i]['machine']\n                start_time = max(job_timelines[j], machine_timelines[m])\n                job_schedule.append({\n                    'machine': m,\n                    'duration': jobs[j][i]['duration'],\n                    'start': start_time\n                })\n                job_timelines[j] = start_time + jobs[j][i]['duration']\n                machine_timelines[m] = start_time + jobs[j][i]['duration']\n            solution.append(job_schedule)\n        return solution\n    \n    # Generate initial population\n    population_size = 20\n    population = []\n    \n    # Add CP-SAT solutions\n    for _ in range(5):\n        cp_solution = generate_cp_sat_solution()\n        if cp_solution:\n            population.append(cp_solution)\n    \n    # Fill rest with random solutions\n    while len(population) < population_size:\n        population.append(generate_random_solution())\n    \n    # Evaluate population\n    def evaluate_solution(solution):\n        makespan = 0\n        for job in solution:\n            last_op = job[-1]\n            end_time = last_op['start'] + last_op['duration']\n            if end_time > makespan:\n                makespan = end_time\n        return makespan\n    \n    # Local search: 2-opt on operation sequences\n    def local_search_2opt(solution):\n        best_solution = solution\n        best_makespan = evaluate_solution(solution)\n        improved = True\n        \n        while improved and (time.time() - _START_TIME) < 0.8 * TIMEOUT_SEC:\n            improved = False\n            for j1 in range(n_jobs):\n                for j2 in range(j1 + 1, n_jobs):\n                    for i1 in range(len(durations[j1])):\n                        for i2 in range(len(durations[j2])):\n                            # Skip if operations are on different machines\n                            if solution[j1][i1]['machine'] != solution[j2][i2]['machine']:\n                                continue\n                            \n                            # Create new solution by swapping operations\n                            new_solution = [job.copy() for job in solution]\n                            new_solution[j1][i1], new_solution[j2][i2] = new_solution[j2][i2], new_solution[j1][i1]\n                            \n                            # Recalculate start times\n                            new_solution = recalculate_start_times(new_solution)\n                            new_makespan = evaluate_solution(new_solution)\n                            \n                            if new_makespan < best_makespan:\n                                best_solution = new_solution\n                                best_makespan = new_makespan\n                                improved = True\n                                break\n                        if improved:\n                            break\n                    if improved:\n                        break\n                if improved:\n                    break\n        \n        return best_solution\n    \n    def recalculate_start_times(solution):\n        machine_timelines = [0] * n_machines\n        job_timelines = [0] * n_jobs\n        new_solution = []\n        \n        for j in range(n_jobs):\n            job_schedule = []\n            for i in range(len(durations[j])):\n                m = solution[j][i]['machine']\n                start_time = max(job_timelines[j], machine_timelines[m])\n                job_schedule.append({\n                    'machine': m,\n                    'duration': solution[j][i]['duration'],\n                    'start': start_time\n                })\n                job_timelines[j] = start_time + solution[j][i]['duration']\n                machine_timelines[m] = start_time + solution[j][i]['duration']\n            new_solution.append(job_schedule)\n        \n        return new_solution\n    \n    # Genetic algorithm parameters\n    mutation_rate = 0.1\n    crossover_rate = 0.8\n    elitism_count = 2\n    \n    # Main evolutionary loop\n    best_solution = min(population, key=evaluate_solution)\n    best_makespan = evaluate_solution(best_solution)\n    \n    while (time.time() - _START_TIME) < 0.8 * TIMEOUT_SEC:\n        # Create new population\n        new_population = []\n        \n        # Elitism: keep best solutions\n        population.sort(key=evaluate_solution)\n        new_population.extend(population[:elitism_count])\n        \n        # Generate offspring\n        while len(new_population) < population_size:\n            # Selection: tournament selection\n            parent1 = min(random.sample(population, 3), key=evaluate_solution)\n            parent2 = min(random.sample(population, 3), key=evaluate_solution)\n            \n            # Crossover\n            if random.random() < crossover_rate:\n                child = crossover(parent1, parent2)\n            else:\n                child = random.choice([parent1, parent2])\n            \n            # Mutation\n            if random.random() < mutation_rate:\n                child = mutate(child)\n            \n            # Local search\n            child = local_search_2opt(child)\n            \n            new_population.append(child)\n        \n        population = new_population\n        \n        # Update best solution\n        current_best = min(population, key=evaluate_solution)\n        current_best_makespan = evaluate_solution(current_best)\n        \n        if current_best_makespan < best_makespan:\n            best_solution = current_best\n            best_makespan = current_best_makespan\n    \n    return best_solution\n\ndef crossover(parent1, parent2):\n    \"\"\"\n    Performs crossover between two parent solutions using job-based crossover.\n    \"\"\"\n    n_jobs = len(parent1)\n    crossover_point = random.randint(1, n_jobs - 1)\n    \n    child = []\n    for j in range(n_jobs):\n        if j < crossover_point:\n            child.append(parent1[j])\n        else:\n            child.append(parent2[j])\n    \n    return child\n\ndef mutate(solution):\n    \"\"\"\n    Performs mutation by swapping operations within a job or between jobs.\n    \"\"\"\n    n_jobs = len(solution)\n    \n    if random.random() < 0.5:\n        # Swap operations within a job\n        j = random.randint(0, n_jobs - 1)\n        if len(solution[j]) > 1:\n            i1, i2 = random.sample(range(len(solution[j])), 2)\n            solution[j][i1], solution[j][i2] = solution[j][i2], solution[j][i1]\n    else:\n        # Swap operations between jobs (if on same machine)\n        j1, j2 = random.sample(range(n_jobs), 2)\n        i1 = random.randint(0, len(solution[j1]) - 1)\n        i2 = random.randint(0, len(solution[j2]) - 1)\n        \n        if solution[j1][i1]['machine'] == solution[j2][i2]['machine']:\n            solution[j1][i1], solution[j2][i2] = solution[j2][i2], solution[j1][i1]\n    \n    return solution"
