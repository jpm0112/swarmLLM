    source_refs[0]:
    approach: Beam search with greedy fallback for job shop scheduling
    code: "import heapq\nimport time\nfrom collections import defaultdict\n\ndef solve(jobs: list[list[dict]]) -> list[list[dict]]:\n    # Extract number of jobs and machines\n    num_jobs = len(jobs)\n    num_machines = max(max(op['machine'] for op in job) for job in jobs) + 1 if jobs else 0\n    \n    # Precompute operation indices for each job\n    job_ops = [[(op['machine'], op['duration'], idx) for idx, op in enumerate(job)] for job in jobs]\n    \n    # Beam search parameters\n    beam_width = 100\n    max_time = 120.0\n    start_time = time.time()\n    \n    # Priority queue for beam search: (makespan, schedule_state)\n    # schedule_state: (current_time_per_machine, next_op_index_per_job, partial_schedule)\n    initial_machine_times = [0] * num_machines\n    initial_next_op = [0] * num_jobs\n    initial_schedule = [[] for _ in range(num_jobs)]\n    \n    heap = []\n    heapq.heappush(heap, (0, (initial_machine_times, initial_next_op, initial_schedule)))\n    \n    best_makespan = float('inf')\n    best_schedule = None\n    \n    while heap and (time.time() - start_time) < 0.8 * max_time:\n        current_makespan, state = heapq.heappop(heap)\n        machine_times, next_op, schedule = state\n        \n        # Check if all jobs are completed\n        if all(idx == len(job) for idx, job in zip(next_op, job_ops)):\n            if current_makespan < best_makespan:\n                best_makespan = current_makespan\n                best_schedule = schedule\n            continue\n        \n        # Generate all possible next operations\n        candidates = []\n        for job_idx in range(num_jobs):\n            if next_op[job_idx] < len(job_ops[job_idx]):\n                machine, duration, op_idx = job_ops[job_idx][next_op[job_idx]]\n                \n                # Check if previous operation in this job is completed\n                if next_op[job_idx] > 0:\n                    prev_start = schedule[job_idx][-1]['start']\n                    prev_duration = schedule[job_idx][-1]['duration']\n                    job_available_time = prev_start + prev_duration\n                else:\n                    job_available_time = 0\n                \n                # Earliest start time for this operation\n                start_time_op = max(machine_times[machine], job_available_time)\n                end_time_op = start_time_op + duration\n                \n                # Create new state\n                new_machine_times = machine_times.copy()\n                new_machine_times[machine] = end_time_op\n                \n                new_next_op = next_op.copy()\n                new_next_op[job_idx] += 1\n                \n                new_schedule = [op.copy() for op in schedule[job_idx]]\n                new_schedule.append({\n                    'machine': machine,\n                    'duration': duration,\n                    'start': start_time_op\n                })\n                \n                new_state_schedule = [op.copy() for op in schedule]\n                new_state_schedule[job_idx] = new_schedule\n                \n                candidates.append((end_time_op, (new_machine_times, new_next_op, new_state_schedule)))\n        \n        # Keep top k candidates\n        if candidates:\n            # Sort candidates by makespan (end_time_op)\n            candidates.sort(key=lambda x: x[0])\n            for makespan, state in candidates[:beam_width]:\n                heapq.heappush(heap, (makespan, state))\n    \n    # If we found a solution, return it\n    if best_schedule is not None:\n        return best_schedule\n    \n    # Fallback: simple greedy dispatching if beam search didn't complete\n    machine_available = [0] * num_machines\n    job_next_op = [0] * num_jobs\n    job_available = [0] * num_jobs\n    schedule = [[] for _ in range(num_jobs)]\n    \n    while any(job_next_op[job_idx] < len(jobs[job_idx]) for job_idx in range(num_jobs)):\n        # Find all operations that can be scheduled now\n        schedulable = []\n        for job_idx in range(num_jobs):\n            if job_next_op[job_idx] < len(jobs[job_idx]):\n                op = jobs[job_idx][job_next_op[job_idx]]\n                machine = op['machine']\n                duration = op['duration']\n                \n                # Check if job is available and machine is available\n                if job_available[job_idx] <= machine_available[machine]:\n                    start_time = machine_available[machine]\n                else:\n                    start_time = job_available[job_idx]\n                \n                schedulable.append((start_time, job_idx, machine, duration))\n        \n        if not schedulable:\n            break\n        \n        # Schedule the operation with earliest possible start time\n        schedulable.sort()\n        start_time, job_idx, machine, duration = schedulable[0]\n        \n        # Update state\n        machine_available[machine] = start_time + duration\n        job_available[job_idx] = start_time + duration\n        job_next_op[job_idx] += 1\n        \n        # Add to schedule\n        schedule[job_idx].append({\n            'machine': machine,\n            'duration': duration,\n            'start': start_time\n        })\n    \n    return schedule"
