    source_refs[0]:
    approach: Priority-based scheduling with corrected operation ordering
    code: "import time\nimport numpy as np\n\ndef solve(jobs: list[list[dict]]) -> list[list[dict]]:\n    # Precompute instance features\n    n_jobs = len(jobs)\n    n_machines = max(max(op['machine'] for op in job) for job in jobs) + 1\n    \n    # Extract processing times for feature computation\n    processing_times = []\n    for job in jobs:\n        for op in job:\n            processing_times.append(op['duration'])\n    \n    # Compute features for the instance\n    max_pt = max(processing_times) if processing_times else 1\n    max_job_length = max(len(job) for job in jobs) if jobs else 1\n    \n    # Create a list of all operations with their metadata\n    operations = []\n    for job_idx, job in enumerate(jobs):\n        for op_idx, op in enumerate(job):\n            operations.append({\n                'job_idx': job_idx,\n                'op_idx': op_idx,\n                'machine': op['machine'],\n                'duration': op['duration'],\n                'job_length': len(job),\n                'machine_load': sum(1 for j in jobs for o in j if o['machine'] == op['machine'])\n            })\n    \n    # Sort operations by priority (descending)\n    # Priority is based on operation position in job and duration\n    def get_priority(op):\n        pos_norm = op['op_idx'] / (op['job_length'] - 1) if op['job_length'] > 1 else 0.5\n        dur_norm = op['duration'] / max_pt if max_pt > 0 else 0\n        mach_load_norm = op['machine_load'] / (n_jobs * n_machines)\n        return (pos_norm * 0.7 + dur_norm * 0.3) * (1 + mach_load_norm * 0.2)\n    \n    operations.sort(key=get_priority, reverse=True)\n    \n    # Initialize result structure\n    result_jobs = [[] for _ in range(n_jobs)]\n    machine_availability = [0] * n_machines\n    job_completion = [0] * n_jobs\n    \n    # Process operations in priority order\n    for op in operations:\n        job_idx = op['job_idx']\n        op_idx = op['op_idx']\n        machine = op['machine']\n        duration = op['duration']\n        \n        # Earliest possible start time\n        earliest_start = max(\n            job_completion[job_idx],  # Previous operation in job must finish\n            machine_availability[machine]  # Machine must be available\n        )\n        \n        # Schedule this operation\n        start_time = earliest_start\n        end_time = start_time + duration\n        \n        # Update machine and job availability\n        machine_availability[machine] = end_time\n        job_completion[job_idx] = end_time\n        \n        # Store the result in the correct position within the job\n        # Ensure we maintain the original operation order\n        while len(result_jobs[job_idx]) <= op_idx:\n            result_jobs[job_idx].append(None)\n        result_jobs[job_idx][op_idx] = {\n            'machine': machine,\n            'duration': duration,\n            'start': start_time\n        }\n    \n    # Fill in any missing operations (shouldn't happen but just in case)\n    for job_idx in range(n_jobs):\n        for op_idx in range(len(jobs[job_idx])):\n            if result_jobs[job_idx][op_idx] is None:\n                op = jobs[job_idx][op_idx]\n                machine = op['machine']\n                duration = op['duration']\n                \n                # Find earliest possible start time\n                prev_op_end = result_jobs[job_idx][op_idx-1]['start'] + result_jobs[job_idx][op_idx-1]['duration'] if op_idx > 0 else 0\n                machine_avail = machine_availability[machine]\n                start_time = max(prev_op_end, machine_avail)\n                \n                result_jobs[job_idx][op_idx] = {\n                    'machine': machine,\n                    'duration': duration,\n                    'start': start_time\n                }\n                \n                # Update availability\n                machine_availability[machine] = start_time + duration\n                job_completion[job_idx] = start_time + duration\n    \n    return result_jobs"
