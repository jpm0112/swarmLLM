    approach: Large Neighborhood Search (LNS) on top of CP-SAT with iterative relaxation and re-solving
    code: "from ortools.sat.python import cp_model\nimport time\nimport random\n\nTIMEOUT_SEC = 120\n_START_TIME = time.time()\n\ndef solve(jobs: list[list[dict]]) -> list[list[dict]]:\n    # Extract problem data\n    num_jobs = len(jobs)\n    num_machines = max(max(op['machine'] for op in job) for job in jobs) + 1\n    \n    # Initialize CP-SAT model and get initial solution\n    initial_schedule, initial_makespan = solve_with_cp(jobs, num_jobs, num_machines)\n    \n    # Set initial best solution\n    best_schedule = [job.copy() for job in initial_schedule]\n    best_makespan = initial_makespan\n    \n    # LNS parameters\n    max_iterations = 100\n    relaxation_size = max(1, num_jobs // 5)  # Relax 20% of jobs\n    \n    # Main LNS loop\n    for iteration in range(max_iterations):\n        # Check for timeout\n        if time.time() - _START_TIME > 0.8 * TIMEOUT_SEC:\n            break\n        \n        # Select a subset of jobs to relax (randomly)\n        jobs_to_relax = random.sample(range(num_jobs), min(relaxation_size, num_jobs))\n        \n        # Solve relaxed problem\n        relaxed_schedule, relaxed_makespan = solve_relaxed_cp(\n            jobs, num_jobs, num_machines, jobs_to_relax, best_schedule\n        )\n        \n        # Accept if improved\n        if relaxed_makespan < best_makespan:\n            best_schedule = [job.copy() for job in relaxed_schedule]\n            best_makespan = relaxed_makespan\n    \n    return best_schedule\n\ndef solve_with_cp(jobs, num_jobs, num_machines):\n    \"\"\"Solve the full problem with CP-SAT to get initial solution\"\"\"\n    model = cp_model.CpModel()\n    all_ops = []\n    \n    for job_idx, job in enumerate(jobs):\n        for op_idx, op in enumerate(job):\n            start_var = model.NewIntVar(0, 1000000, f'start_{job_idx}_{op_idx}')\n            duration = op['duration']\n            end_var = model.NewIntVar(0, 1000000, f'end_{job_idx}_{op_idx}')\n            model.Add(end_var == start_var + duration)\n            \n            all_ops.append({\n                'job': job_idx,\n                'op': op_idx,\n                'machine': op['machine'],\n                'start': start_var,\n                'end': end_var,\n                'duration': duration\n            })\n    \n    # Precedence constraints\n    for job_idx, job in enumerate(jobs):\n        for op_idx in range(1, len(job)):\n            prev_op = all_ops[job_idx * len(job) + op_idx - 1]\n            curr_op = all_ops[job_idx * len(job) + op_idx]\n            model.Add(curr_op['start'] >= prev_op['end'])\n    \n    # Machine constraints\n    for machine in range(num_machines):\n        machine_ops = [op for op in all_ops if op['machine'] == machine]\n        if machine_ops:\n            intervals = []\n            for op in machine_ops:\n                interval = model.NewIntervalVar(op['start'], op['duration'], op['end'], \n                                               f'interval_{op[\"job\"]}_{op[\"op\"]}')\n                intervals.append(interval)\n            model.AddNoOverlap(intervals)\n    \n    # Objective\n    makespan = model.NewIntVar(0, 1000000, 'makespan')\n    model.AddMaxEquality(makespan, [op['end'] for op in all_ops])\n    model.Minimize(makespan)\n    \n    # Solve\n    solver = cp_model.CpSolver()\n    remaining_time = TIMEOUT_SEC - (time.time() - _START_TIME)\n    solver.parameters.max_time_in_seconds = 0.1 * remaining_time  # Short initial solve\n    \n    status = solver.Solve(model)\n    \n    # Build solution\n    schedule = []\n    for job_idx, job in enumerate(jobs):\n        scheduled_job = []\n        for op_idx, op in enumerate(job):\n            op_start = solver.Value(all_ops[job_idx * len(job) + op_idx]['start'])\n            scheduled_op = {\n                'machine': op['machine'],\n                'duration': op['duration'],\n                'start': op_start\n            }\n            scheduled_job.append(scheduled_op)\n        schedule.append(scheduled_job)\n    \n    makespan = max(op['start'] + op['duration'] for job in schedule for op in job)\n    return schedule, makespan\n\ndef solve_relaxed_cp(jobs, num_jobs, num_machines, jobs_to_relax, reference_schedule):\n    \"\"\"Solve with some start times fixed (LNS relaxation)\"\"\"\n    model = cp_model.CpModel()\n    all_ops = []\n    \n    for job_idx, job in enumerate(jobs):\n        for op_idx, op in enumerate(job):\n            if job_idx in jobs_to_relax:\n                # Relaxed job - create variable\n                start_var = model.NewIntVar(0, 1000000, f'start_{job_idx}_{op_idx}')\n            else:\n                # Fixed job - use reference schedule value\n                ref_start = reference_schedule[job_idx][op_idx]['start']\n                start_var = model.NewConstant(ref_start)\n            \n            duration = op['duration']\n            end_var = model.NewIntVar(0, 1000000, f'end_{job_idx}_{op_idx}')\n            model.Add(end_var == start_var + duration)\n            \n            all_ops.append({\n                'job': job_idx,\n                'op': op_idx,\n                'machine': op['machine'],\n                'start': start_var,\n                'end': end_var,\n                'duration': duration\n            })\n    \n    # Precedence constraints (only for relaxed jobs)\n    for job_idx in jobs_to_relax:\n        job = jobs[job_idx]\n        for op_idx in range(1, len(job)):\n            prev_op = all_ops[job_idx * len(job) + op_idx - 1]\n            curr_op = all_ops[job_idx * len(job) + op_idx]\n            model.Add(curr_op['start'] >= prev_op['end'])\n    \n    # Machine constraints (only for machines used by relaxed jobs)\n    for machine in range(num_machines):\n        machine_ops = [op for op in all_ops if op['machine'] == machine]\n        if any(op['job'] in jobs_to_relax for op in machine_ops):\n            intervals = []\n            for op in machine_ops:\n                interval = model.NewIntervalVar(op['start'], op['duration'], op['end'],\n                                               f'interval_{op[\"job\"]}_{op[\"op\"]}')\n                intervals.append(interval)\n            model.AddNoOverlap(intervals)\n    \n    # Objective\n    makespan = model.NewIntVar(0, 1000000, 'makespan')\n    model.AddMaxEquality(makespan, [op['end'] for op in all_ops if op['job'] in jobs_to_relax])\n    model.Minimize(makespan)\n    \n    # Solve with shorter time limit\n    solver = cp_model.CpSolver()\n    remaining_time = TIMEOUT_SEC - (time.time() - _START_TIME)\n    solver.parameters.max_time_in_seconds = 0.05 * remaining_time  # Very short for LNS iterations\n    \n    status = solver.Solve(model)\n    \n    # Build solution\n    schedule = []\n    for job_idx, job in enumerate(jobs):\n        scheduled_job = []\n        for op_idx, op in enumerate(job):\n            if job_idx in jobs_to_relax:\n                op_start = solver.Value(all_ops[job_idx * len(job) + op_idx]['start'])\n            else:\n                op_start = reference_schedule[job_idx][op_idx]['start']\n            \n            scheduled_op = {\n                'machine': op['machine'],\n                'duration': op['duration'],\n                'start': op_start\n            }\n            scheduled_job.append(scheduled_op)\n        schedule.append(scheduled_job)\n    \n    makespan = max(op['start'] + op['duration'] for job in schedule for op in job)\n    return schedule, makespan"
