    approach: "Refined MILP with tightened big-M constants, precedence cuts, and CP-SAT warm-start"
    code: "import gurobipy as gp\nfrom gurobipy import GRB\nfrom ortools.sat.python import cp_model\nimport time\n\ndef solve(jobs: list[list[dict]]) -> list[list[dict]]:\n    # Extract problem data\n    num_jobs = len(jobs)\n    num_machines = max(op['machine'] for job in jobs for op in job) + 1\n    \n    # Create a list of all operations with job index\n    operations = []\n    for job_idx, job in enumerate(jobs):\n        for op in job:\n            operations.append({\n                'job': job_idx,\n                'machine': op['machine'],\n                'duration': op['duration']\n            })\n    \n    num_ops = len(operations)\n    \n    # First, get a warm-start solution using CP-SAT\n    cp_solution = get_cp_solution(jobs, operations, num_jobs, num_machines, num_ops)\n    \n    # Create MILP model\n    try:\n        model = gp.Model('JSP_MILP')\n        model.setParam('OutputFlag', 0)  # Suppress output\n        \n        # Decision variables\n        start = model.addVars(num_ops, vtype=GRB.CONTINUOUS, name='start')\n        makespan = model.addVar(vtype=GRB.CONTINUOUS, name='makespan')\n        \n        # Binary variables for disjunctive constraints\n        x = model.addVars(num_ops, num_ops, vtype=GRB.BINARY, name='x')\n        \n        # Objective: minimize makespan\n        model.setObjective(makespan, GRB.MINIMIZE)\n        \n        # Constraints\n        # 1. Makespan definition\n        for i in range(num_ops):\n            model.addConstr(start[i] + operations[i]['duration'] <= makespan)\n        \n        # 2. Precedence constraints (operations in same job must follow order)\n        for job_idx in range(num_jobs):\n            job_ops = [i for i, op in enumerate(operations) if op['job'] == job_idx]\n            for k in range(len(job_ops) - 1):\n                i = job_ops[k]\n                j = job_ops[k + 1]\n                model.addConstr(start[i] + operations[i]['duration'] <= start[j])\n        \n        # 3. Machine capacity constraints (no overlap on same machine)\n        # Calculate tight big-M constants for each machine\n        machine_big_M = {}\n        for m in range(num_machines):\n            machine_ops = [i for i, op in enumerate(operations) if op['machine'] == m]\n            if machine_ops:\n                # Calculate maximum possible start time difference\n                max_duration = max(operations[i]['duration'] for i in machine_ops)\n                machine_big_M[m] = sum(operations[i]['duration'] for i in machine_ops) - max_duration\n        \n        for m in range(num_machines):\n            machine_ops = [i for i, op in enumerate(operations) if op['machine'] == m]\n            for i_idx in range(len(machine_ops)):\n                for j_idx in range(i_idx + 1, len(machine_ops)):\n                    i = machine_ops[i_idx]\n                    j = machine_ops[j_idx]\n                    # Use tight big-M constant for this machine\n                    M = machine_big_M.get(m, 1000000)\n                    # Either i comes before j or j comes before i\n                    model.addConstr(start[i] + operations[i]['duration'] <= start[j] + M * (1 - x[i, j]))\n                    model.addConstr(start[j] + operations[j]['duration'] <= start[i] + M * x[i, j])\n        \n        # Add precedence cuts (Gomory cuts)\n        for job_idx in range(num_jobs):\n            job_ops = [i for i, op in enumerate(operations) if op['job'] == job_idx]\n            for k in range(len(job_ops) - 2):\n                i = job_ops[k]\n                j = job_ops[k + 1]\n                l = job_ops[k + 2]\n                model.addConstr(start[i] + operations[i]['duration'] + operations[j]['duration'] <= start[l])\n        \n        # Set warm-start from CP solution if available\n        if cp_solution:\n            for i, op in enumerate(operations):\n                start[i].start = cp_solution[i]['start']\n        \n        # Optimize with time limit\n        remaining_time = TIMEOUT_SEC - (time.time() - _START_TIME)\n        model.setParam('TimeLimit', max(0.8 * remaining_time, 1.0))\n        \n        model.optimize()\n        \n        # Extract solution\n        if model.status == GRB.OPTIMAL or model.status == GRB.TIME_LIMIT:\n            solution = []\n            for job in jobs:\n                job_solution = []\n                for op in job:\n                    # Find the corresponding operation in our flat list\n                    for i, oper in enumerate(operations):\n                        if oper['job'] == jobs.index(job) and oper['machine'] == op['machine'] and oper['duration'] == op['duration']:\n                            job_solution.append({\n                                'machine': op['machine'],\n                                'duration': op['duration'],\n                                'start': int(start[i].X + 0.5)  # Round to nearest int\n                            })\n                            break\n                solution.append(job_solution)\n            return solution\n    except Exception as e:\n        pass\n    \n    # Fallback: return CP solution if available, otherwise use greedy dispatching\n    if cp_solution:\n        return cp_solution\n    \n    # Greedy dispatching fallback\n    solution = []\n    machine_avail = [0] * num_machines\n    job_start = [0] * num_jobs\n    \n    for job_idx, job in enumerate(jobs):\n        job_ops = []\n        for op in job:\n            m = op['machine']\n            start_time = max(job_start[job_idx], machine_avail[m])\n            job_ops.append({\n                'machine': m,\n                'duration': op['duration'],\n                'start': start_time\n            })\n            job_start[job_idx] = start_time + op['duration']\n            machine_avail[m] = start_time + op['duration']\n        solution.append(job_ops)\n    return solution\n\ndef get_cp_solution(jobs, operations, num_jobs, num_machines, num_ops):\n    \"\"\"Get a warm-start solution using CP-SAT solver\"\"\"\n    try:\n        # Create CP-SAT model\n        model = cp_model.CpModel()\n        \n        # Create variables\n        all_ops = []\n        for job_idx, job in enumerate(jobs):\n            for op_idx, op in enumerate(job):\n                # Start time variable\n                start_var = model.NewIntVar(0, 1000000, f'start_{job_idx}_{op_idx}')\n                # Duration is fixed\n                duration = op['duration']\n                # End time variable\n                end_var = model.NewIntVar(0, 1000000, f'end_{job_idx}_{op_idx}')\n                # Link start, duration, and end\n                model.Add(end_var == start_var + duration)\n                \n                all_ops.append({\n                    'job': job_idx,\n                    'op': op_idx,\n                    'machine': op['machine'],\n                    'start': start_var,\n                    'end': end_var,\n                    'duration': duration\n                })\n        \n        # Add precedence constraints\n        for job_idx, job in enumerate(jobs):\n            for op_idx in range(1, len(job)):\n                prev_op = all_ops[job_idx * len(job) + op_idx - 1]\n                curr_op = all_ops[job_idx * len(job) + op_idx]\n                model.Add(curr_op['start'] >= prev_op['end'])\n        \n        # Add machine capacity constraints\n        for machine in range(num_machines):\n            machine_ops = [op for op in all_ops if op['machine'] == machine]\n            \n            if machine_ops:\n                intervals = []\n                for op in machine_ops:\n                    interval = model.NewIntervalVar(op['start'], op['duration'], op['end'], f'interval_{op[\"job\"]}_{op[\"op\"]}')\n                    intervals.append(interval)\n                \n                model.AddNoOverlap(intervals)\n        \n        # Objective: minimize makespan\n        makespan = model.NewIntVar(0, 1000000, 'makespan')\n        model.AddMaxEquality(makespan, [op['end'] for op in all_ops])\n        model.Minimize(makespan)\n        \n        # Solve with time limit\n        solver = cp_model.CpSolver()\n        remaining_time = TIMEOUT_SEC - (time.time() - _START_TIME)\n        solver.parameters.max_time_in_seconds = 0.3 * remaining_time  # Use 30% of time for warm-start\n        \n        status = solver.Solve(model)\n        \n        # Build solution\n        if status == cp_model.OPTIMAL or status == cp_model.FEASIBLE:\n            solution = []\n            for job_idx, job in enumerate(jobs):\n                scheduled_job = []\n                for op_idx, op in enumerate(job):\n                    op_start = solver.Value(all_ops[job_idx * len(job) + op_idx]['start'])\n                    scheduled_op = {\n                        'machine': op['machine'],\n                        'duration': op['duration'],\n                        'start': op_start\n                    }\n                    scheduled_job.append(scheduled_op)\n                solution.append(scheduled_job)\n            return solution\n    except Exception as e:\n        pass\n    \n    return None"
