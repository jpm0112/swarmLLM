  - record_type: agent_attempt
    iteration: 1
    agent_id: 1
    mode: explore
    direction: "Develop a genetic algorithm that encodes operation sequences as chromosomes, uses order‑based crossover, and applies a schedule‑feasibility repair step after each mutation."
    source_refs[0]:
    approach: Genetic Algorithm with feasibility repair and greedy decoding for Job Shop Scheduling
    code: "import random\nimport time\nfrom typing import List, Dict, Any\n\n# Pre-defined globals for timeout handling\nTIMEOUT_SEC = 120\n_START_TIME = time.time()\n\n\ndef solve(jobs: List[List[Dict[str, Any]]]) -> List[List[Dict[str, Any]]]:\n    \"\"\"\n    Solves the Job Shop Scheduling Problem using a Genetic Algorithm with order-based crossover\n    and a feasibility repair step to ensure valid schedules.\n    \"\"\"\n    # Handle empty input\n    if not jobs:\n        return []\n    \n    # Extract number of jobs and machines\n    num_jobs = len(jobs)\n    num_machines = max(op[\"machine\"] for job in jobs for op in job) + 1\n    \n    # Best solution tracking\n    best_solution = None\n    best_makespan = float('inf')\n    \n    # Genetic Algorithm parameters\n    population_size = 50\n    max_generations = 1000\n    mutation_rate = 0.1\n    elitism_count = 2\n    \n    # Early stopping if timeout is near\n    def should_stop():\n        return (time.time() - _START_TIME) > 0.8 * TIMEOUT_SEC\n    \n    # Generate initial population: each chromosome is a list of (job_id, op_index)\n    def generate_initial_population():\n        population = []\n        for _ in range(population_size):\n            chromosome = []\n            for job_id in range(num_jobs):\n                for op_idx in range(len(jobs[job_id])):\n                    chromosome.append((job_id, op_idx))\n            random.shuffle(chromosome)\n            population.append(chromosome)\n        return population\n    \n    # Decode chromosome into a schedule using a greedy dispatching rule\n    def decode_chromosome(chromosome: List[tuple]) -> List[List[Dict[str, Any]]]:\n        # Initialize machine availability and job operation pointers\n        machine_available = [0] * num_machines\n        job_next_op = [0] * num_jobs\n        job_completion = [0] * num_jobs\n        schedule = [[op.copy() for op in job] for job in jobs]\n        \n        for job_id, op_idx in chromosome:\n            if op_idx != job_next_op[job_id]:\n                continue  # Skip if not the next operation in the job\n            \n            machine = jobs[job_id][op_idx][\"machine\"]\n            duration = jobs[job_id][op_idx][\"duration\"]\n            \n            # Determine start time (max of machine availability and previous operation completion)\n            start_time = max(machine_available[machine], job_completion[job_id])\n            \n            # Update machine and job state\n            machine_available[machine] = start_time + duration\n            job_completion[job_id] = start_time + duration\n            job_next_op[job_id] += 1\n            \n            # Record start time in schedule\n            schedule[job_id][op_idx][\"start\"] = start_time\n        \n        return schedule\n    \n    # Calculate makespan of a schedule\n    def calculate_makespan(schedule: List[List[Dict[str, Any]]]) -> int:\n        makespan = 0\n        for job in schedule:\n            for op in job:\n                end_time = op[\"start\"] + op[\"duration\"]\n                if end_time > makespan:\n                    makespan = end_time\n        return makespan\n    \n    # Order-based crossover (OX)\n    def order_based_crossover(parent1: List[tuple], parent2: List[tuple]) -> List[tuple]:\n        size = len(parent1)\n        # Select two random cut points\n        a, b = sorted(random.sample(range(size), 2))\n        child = [None] * size\n        \n        # Copy segment from parent1\n        child[a:b] = parent1[a:b]\n        \n        # Fill remaining positions with genes from parent2 in order, skipping duplicates\n        ptr = b\n        for gene in parent2[b:] + parent2[:b]:\n            if gene not in child:\n                if ptr >= size:\n                    ptr = 0\n                if child[ptr] is None:\n                    child[ptr] = gene\n                    ptr += 1\n        \n        return child\n    \n    # Mutation: swap two genes with a small probability\n    def mutate(chromosome: List[tuple]) -> List[tuple]:\n        if random.random() < mutation_rate:\n            a, b = random.sample(range(len(chromosome)), 2)\n            chromosome[a], chromosome[b] = chromosome[b], chromosome[a]\n        return chromosome\n    \n    # Feasibility repair: ensure operations within a job are in order\n    def repair_chromosome(chromosome: List[tuple]) -> List[tuple]:\n        # For each job, ensure operations appear in order\n        for job_id in range(num_jobs):\n            op_indices = [i for i, (jid, opidx) in enumerate(chromosome) if jid == job_id]\n            # Sort by operation index to maintain job order\n            op_indices_sorted = sorted(op_indices, key=lambda i: chromosome[i][1])\n            # Reorder the chromosome to respect job operation order\n            new_order = []\n            for idx in op_indices_sorted:\n                new_order.append(chromosome[idx])\n            # Replace the job's operations in the chromosome\n            for pos, idx in enumerate(op_indices):\n                chromosome[idx] = new_order[pos]\n        return chromosome\n    \n    # Main GA loop\n    population = generate_initial_population()\n    generation = 0\n    \n    while generation < max_generations and not should_stop():\n        # Evaluate population\n        schedules = [decode_chromosome(chromosome) for chromosome in population]\n        makespans = [calculate_makespan(schedule) for schedule in schedules]\n        \n        # Track best solution\n        current_best_idx = makespans.index(min(makespans))\n        current_best_makespan = makespans[current_best_idx]\n        if current_best_makespan < best_makespan:\n            best_makespan = current_best_makespan\n            best_solution = schedules[current_best_idx]\n        \n        # Selection: tournament selection\n        selected = []\n        for _ in range(population_size):\n            candidates = random.sample(list(zip(population, makespans)), 3)\n            winner = min(candidates, key=lambda x: x[1])[0]\n            selected.append(winner)\n        \n        # Crossover and mutation\n        new_population = []\n        for i in range(0, population_size - elitism_count, 2):\n            parent1, parent2 = selected[i], selected[i+1]\n            child1 = order_based_crossover(parent1, parent2)\n            child2 = order_based_crossover(parent2, parent1)\n            child1 = mutate(child1)\n            child2 = mutate(child2)\n            child1 = repair_chromosome(child1)\n            child2 = repair_chromosome(child2)\n            new_population.extend([child1, child2])\n        \n        # Elitism: carry over best solutions\n        elite_indices = sorted(range(len(makespans)), key=lambda i: makespans[i])[:elitism_count]\n        for idx in elite_indices:\n            new_population.append(population[idx])\n        \n        population = new_population\n        generation += 1\n    \n    # Ensure we return the best solution found\n    if best_solution is None:\n        # Fallback: greedy dispatching if GA didn't run\n        chromosome = [(job_id, op_idx) for job_id in range(num_jobs) for op_idx in range(len(jobs[job_id]))]\n        best_solution = decode_chromosome(chromosome)\n    \n    return best_solution"
