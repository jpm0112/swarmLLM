    direction: Design a simulated annealing algorithm that perturbs a feasible schedule by reordering operations on the critical path and accepts worse solutions based on a temperature schedule.
    source_refs[0]:
    approach: Simulated Annealing with Critical Path Perturbation
    code: "import random\nimport math\nimport time\n\nTIMEOUT_SEC = 120\n_START_TIME = time.time()\n\ndef solve(jobs: list[list[dict]]) -> list[list[dict]]:\n    # Extract number of machines\n    machines = set()\n    for job in jobs:\n        for op in job:\n            machines.add(op[\"machine\"])\n    num_machines = max(machines) + 1\n    \n    # Initialize a feasible schedule using a simple dispatching rule (e.g., FIFO)\n    current_schedule = initialize_schedule(jobs, num_machines)\n    current_makespan = calculate_makespan(current_schedule)\n    \n    best_schedule = [job.copy() for job in current_schedule]\n    best_makespan = current_makespan\n    \n    # Simulated Annealing parameters\n    initial_temp = 1000\n    final_temp = 1\n    cooling_rate = 0.99\n    \n    temp = initial_temp\n    \n    while temp > final_temp:\n        # Check for timeout\n        if time.time() - _START_TIME > 0.8 * TIMEOUT_SEC:\n            break\n        \n        # Generate a neighbor by perturbing the critical path\n        neighbor_schedule = perturb_schedule(current_schedule, num_machines)\n        neighbor_makespan = calculate_makespan(neighbor_schedule)\n        \n        # Decide whether to accept the neighbor\n        delta = neighbor_makespan - current_makespan\n        if delta < 0 or random.random() < math.exp(-delta / temp):\n            current_schedule = neighbor_schedule\n            current_makespan = neighbor_makespan\n            \n            # Update best solution\n            if current_makespan < best_makespan:\n                best_schedule = [job.copy() for job in current_schedule]\n                best_makespan = current_makespan\n        \n        # Cool down\n        temp *= cooling_rate\n    \n    return best_schedule\n\ndef initialize_schedule(jobs: list[list[dict]], num_machines: int) -> list[list[dict]]:\n    \"\"\"Initialize a feasible schedule using a simple dispatching rule.\"\"\"\n    schedule = []\n    machine_availability = [0] * num_machines\n    \n    for job in jobs:\n        scheduled_job = []\n        for op in job:\n            machine = op[\"machine\"]\n            duration = op[\"duration\"]\n            \n            # Start time is the maximum of machine availability and previous operation's finish time\n            if scheduled_job:\n                prev_finish = scheduled_job[-1][\"start\"] + scheduled_job[-1][\"duration\"]\n                start = max(machine_availability[machine], prev_finish)\n            else:\n                start = machine_availability[machine]\n            \n            scheduled_op = {\n                \"machine\": machine,\n                \"duration\": duration,\n                \"start\": start\n            }\n            scheduled_job.append(scheduled_op)\n            \n            # Update machine availability\n            machine_availability[machine] = start + duration\n        \n        schedule.append(scheduled_job)\n    \n    return schedule\n\ndef calculate_makespan(schedule: list[list[dict]]) -> int:\n    \"\"\"Calculate the makespan of a given schedule.\"\"\"\n    makespan = 0\n    for job in schedule:\n        for op in job:\n            finish_time = op[\"start\"] + op[\"duration\"]\n            if finish_time > makespan:\n                makespan = finish_time\n    return makespan\n\ndef perturb_schedule(schedule: list[list[dict]], num_machines: int) -> list[list[dict]]:\n    \"\"\"Perturb the schedule by reordering operations on the critical path.\"\"\"\n    # Identify the critical path\n    critical_path = identify_critical_path(schedule)\n    \n    if not critical_path:\n        return schedule\n    \n    # Randomly select two operations on the critical path to swap\n    if len(critical_path) < 2:\n        return schedule\n    \n    idx1, idx2 = random.sample(range(len(critical_path)), 2)\n    op1 = critical_path[idx1]\n    op2 = critical_path[idx2]\n    \n    # Ensure the operations are on the same machine\n    if op1[\"machine\"] != op2[\"machine\"]:\n        return schedule\n    \n    # Swap the operations in their respective jobs\n    new_schedule = [job.copy() for job in schedule]\n    \n    # Find the jobs and positions of the operations\n    job1, pos1 = find_operation(new_schedule, op1)\n    job2, pos2 = find_operation(new_schedule, op2)\n    \n    # Swap the operations\n    new_schedule[job1][pos1], new_schedule[job2][pos2] = new_schedule[job2][pos2], new_schedule[job1][pos1]\n    \n    # Recalculate the schedule to ensure feasibility\n    new_schedule = recalculate_schedule(new_schedule, num_machines)\n    \n    return new_schedule\n\ndef identify_critical_path(schedule: list[list[dict]]) -> list[dict]:\n    \"\"\"Identify the critical path in the schedule.\"\"\"\n    # Find the operation with the latest finish time\n    critical_ops = []\n    max_finish = 0\n    \n    for job in schedule:\n        for op in job:\n            finish_time = op[\"start\"] + op[\"duration\"]\n            if finish_time > max_finish:\n                max_finish = finish_time\n                critical_ops = [op]\n            elif finish_time == max_finish:\n                critical_ops.append(op)\n    \n    # If there are multiple operations with the same finish time, pick one randomly\n    if critical_ops:\n        return [random.choice(critical_ops)]\n    \n    return []\n\ndef find_operation(schedule: list[list[dict]], op: dict) -> tuple:\n    \"\"\"Find the job and position of a given operation in the schedule.\"\"\"\n    for job_idx, job in enumerate(schedule):\n        for op_idx, operation in enumerate(job):\n            if operation[\"machine\"] == op[\"machine\"] and operation[\"duration\"] == op[\"duration\"] and operation[\"start\"] == op[\"start\"]:\n                return job_idx, op_idx\n    return -1, -1\n\ndef recalculate_schedule(schedule: list[list[dict]], num_machines: int) -> list[list[dict]]:\n    \"\"\"Recalculate the schedule to ensure feasibility after perturbation.\"\"\"\n    new_schedule = []\n    machine_availability = [0] * num_machines\n    \n    for job in schedule:\n        new_job = []\n        for op in job:\n            machine = op[\"machine\"]\n            duration = op[\"duration\"]\n            \n            # Start time is the maximum of machine availability and previous operation's finish time\n            if new_job:\n                prev_finish = new_job[-1][\"start\"] + new_job[-1][\"duration\"]\n                start = max(machine_availability[machine], prev_finish)\n            else:\n                start = machine_availability[machine]\n            \n            new_op = {\n                \"machine\": machine,\n                \"duration\": duration,\n                \"start\": start\n            }\n            new_job.append(new_op)\n            \n            # Update machine availability\n            machine_availability[machine] = start + duration\n        \n        new_schedule.append(new_job)\n    \n    return new_schedule"
