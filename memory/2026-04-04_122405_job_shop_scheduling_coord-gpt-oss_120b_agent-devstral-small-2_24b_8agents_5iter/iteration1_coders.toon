    mode: explore
    direction: "Create a tabu search heuristic that starts from a dispatching rule schedule and explores neighbor moves by swapping adjacent operations on the critical path, maintaining a tabu list of recent moves."
    source_refs[0]:
    approach: Fixed tabu search with proper operation copying and validation
    code: "import time\nimport random\nfrom collections import deque\n\ndef solve(jobs: list[list[dict]]) -> list[list[dict]]:\n    # Extract number of machines\n    num_machines = max(op['machine'] for job in jobs for op in job) + 1\n    \n    # Helper function to calculate makespan and critical path\n    def calculate_makespan_and_critical_path(schedule):\n        machine_timelines = [[] for _ in range(num_machines)]\n        job_completion_times = []\n        \n        for job in schedule:\n            current_time = 0\n            for op in job:\n                machine = op['machine']\n                duration = op['duration']\n                \n                # Find the earliest start time on this machine\n                if not machine_timelines[machine]:\n                    start_time = current_time\n                else:\n                    # Find when machine becomes available\n                    machine_available = max(machine_timelines[machine])\n                    start_time = max(current_time, machine_available)\n                \n                # Update operation start time\n                op['start'] = start_time\n                \n                # Update machine timeline\n                machine_timelines[machine].append(start_time + duration)\n                \n                # Update current time for job precedence\n                current_time = start_time + duration\n            \n            job_completion_times.append(current_time)\n        \n        makespan = max(job_completion_times)\n        \n        # Find critical path (operations that determine the makespan)\n        critical_path = []\n        for job_idx, job in enumerate(schedule):\n            for op in job:\n                if op['start'] + op['duration'] == makespan:\n                    critical_path.append((job_idx, op))\n        \n        return makespan, critical_path\n    \n    # Initial solution using a dispatching rule (Shortest Processing Time first)\n    def initial_solution():\n        # Create a deep copy of jobs to avoid modifying the original\n        initial_schedule = []\n        for job in jobs:\n            new_job = []\n            for op in job:\n                new_op = {'machine': op['machine'], 'duration': op['duration']}\n                new_job.append(new_op)\n            initial_schedule.append(new_job)\n        \n        # Sort jobs by total processing time (SPT rule)\n        initial_schedule.sort(key=lambda job: sum(op['duration'] for op in job))\n        \n        # Calculate makespan and critical path for initial solution\n        makespan, critical_path = calculate_makespan_and_critical_path(initial_schedule)\n        \n        return initial_schedule, makespan, critical_path\n    \n    # Generate neighbor by swapping adjacent operations on the critical path\n    def generate_neighbor(current_schedule, critical_path):\n        # Find all possible adjacent swaps on the critical path\n        neighbor_candidates = []\n        \n        for job_idx, op in critical_path:\n            job = current_schedule[job_idx]\n            op_idx = job.index(op)\n            \n            # Try to swap with previous operation in the job\n            if op_idx > 0:\n                new_job = [{'machine': op['machine'], 'duration': op['duration']} for op in job]\n                new_job[op_idx], new_job[op_idx-1] = new_job[op_idx-1], new_job[op_idx]\n                neighbor_candidates.append((job_idx, new_job))\n            \n            # Try to swap with next operation in the job\n            if op_idx < len(job) - 1:\n                new_job = [{'machine': op['machine'], 'duration': op['duration']} for op in job]\n                new_job[op_idx], new_job[op_idx+1] = new_job[op_idx+1], new_job[op_idx]\n                neighbor_candidates.append((job_idx, new_job))\n        \n        if not neighbor_candidates:\n            return None\n        \n        # Select a random neighbor\n        job_idx, new_job = random.choice(neighbor_candidates)\n        neighbor_schedule = []\n        for i, job in enumerate(current_schedule):\n            if i == job_idx:\n                neighbor_schedule.append(new_job)\n            else:\n                neighbor_schedule.append([{'machine': op['machine'], 'duration': op['duration']} for op in job])\n        \n        return neighbor_schedule\n    \n    # Tabu search implementation\n    def tabu_search(initial_schedule, initial_makespan, initial_critical_path, max_iterations=1000, tabu_tenure=10):\n        best_schedule = initial_schedule\n        best_makespan = initial_makespan\n        current_schedule = initial_schedule\n        current_makespan = initial_makespan\n        current_critical_path = initial_critical_path\n        \n        tabu_list = deque(maxlen=tabu_tenure)\n        \n        for iteration in range(max_iterations):\n            # Check if we should stop due to time limit\n            if time.time() - _START_TIME > 0.8 * TIMEOUT_SEC:\n                break\n            \n            # Generate neighbor\n            neighbor_schedule = generate_neighbor(current_schedule, current_critical_path)\n            \n            if neighbor_schedule is None:\n                break\n            \n            # Calculate makespan for neighbor\n            neighbor_makespan, neighbor_critical_path = calculate_makespan_and_critical_path(neighbor_schedule)\n            \n            # Check if this move is tabu\n            move_is_tabu = False\n            for tabu_move in tabu_list:\n                if tabu_move == (str(current_schedule), str(neighbor_schedule)):\n                    move_is_tabu = True\n                    break\n            \n            # Accept the neighbor if it's better or not tabu\n            if (neighbor_makespan < best_makespan) or (not move_is_tabu and neighbor_makespan < current_makespan):\n                current_schedule = neighbor_schedule\n                current_makespan = neighbor_makespan\n                current_critical_path = neighbor_critical_path\n                \n                # Update best solution if improved\n                if neighbor_makespan < best_makespan:\n                    best_schedule = neighbor_schedule\n                    best_makespan = neighbor_makespan\n                \n                # Add move to tabu list\n                tabu_list.append((str(current_schedule), str(neighbor_schedule)))\n        \n        return best_schedule, best_makespan\n    \n    # Main execution\n    initial_schedule, initial_makespan, initial_critical_path = initial_solution()\n    best_schedule, best_makespan = tabu_search(initial_schedule, initial_makespan, initial_critical_path)\n    \n    return best_schedule"
