    direction: "Implement a constraint programming model using a CP solver (e.g., OR‑Tools CP‑Sat) with cumulative constraints for machine capacities and search with impact‑based variable ordering."
    source_refs[0]:
    approach: Constraint Programming with OR-Tools CP-SAT solver
    code: "from ortools.sat.python import cp_model\nimport time\n\ndef solve(jobs: list[list[dict]]) -> list[list[dict]]:\n    # Extract problem data\n    num_jobs = len(jobs)\n    num_machines = max(max(op['machine'] for op in job) for job in jobs) + 1\n    \n    # Create CP-SAT model\n    model = cp_model.CpModel()\n    \n    # Create variables\n    all_ops = []\n    for job_idx, job in enumerate(jobs):\n        for op_idx, op in enumerate(job):\n            # Start time variable\n            start_var = model.NewIntVar(0, 1000000, f'start_{job_idx}_{op_idx}')\n            # Duration is fixed\n            duration = op['duration']\n            # End time variable\n            end_var = model.NewIntVar(0, 1000000, f'end_{job_idx}_{op_idx}')\n            # Link start, duration, and end\n            model.Add(end_var == start_var + duration)\n            \n            all_ops.append({\n                'job': job_idx,\n                'op': op_idx,\n                'machine': op['machine'],\n                'start': start_var,\n                'end': end_var,\n                'duration': duration\n            })\n    \n    # Add precedence constraints (operations in same job must be in order)\n    for job_idx, job in enumerate(jobs):\n        for op_idx in range(1, len(job)):\n            prev_op = all_ops[job_idx * len(job) + op_idx - 1]\n            curr_op = all_ops[job_idx * len(job) + op_idx]\n            model.Add(curr_op['start'] >= prev_op['end'])\n    \n    # Add machine capacity constraints (no overlapping operations on same machine)\n    for machine in range(num_machines):\n        # Get all operations on this machine\n        machine_ops = [op for op in all_ops if op['machine'] == machine]\n        \n        if machine_ops:\n            # Create intervals for cumulative constraint\n            intervals = []\n            for op in machine_ops:\n                interval = model.NewIntervalVar(op['start'], op['duration'], op['end'], f'interval_{op[\"job\"]}_{op[\"op\"]}')\n                intervals.append(interval)\n            \n            # Add no-overlap constraint (cumulative with capacity 1)\n            model.AddNoOverlap(intervals)\n    \n    # Objective: minimize makespan (maximum end time)\n    makespan = model.NewIntVar(0, 1000000, 'makespan')\n    model.AddMaxEquality(makespan, [op['end'] for op in all_ops])\n    model.Minimize(makespan)\n    \n    # Solve with default parameters\n    solver = cp_model.CpSolver()\n    \n    # Set time limit (80% of timeout)\n    remaining_time = TIMEOUT_SEC - (time.time() - _START_TIME)\n    solver.parameters.max_time_in_seconds = 0.8 * remaining_time\n    \n    # Solve\n    status = solver.Solve(model)\n    \n    # Build solution\n    solution = []\n    for job_idx, job in enumerate(jobs):\n        scheduled_job = []\n        for op_idx, op in enumerate(job):\n            op_start = solver.Value(all_ops[job_idx * len(job) + op_idx]['start'])\n            scheduled_op = {\n                'machine': op['machine'],\n                'duration': op['duration'],\n                'start': op_start\n            }\n            scheduled_job.append(scheduled_op)\n        solution.append(scheduled_job)\n    \n    return solution"
