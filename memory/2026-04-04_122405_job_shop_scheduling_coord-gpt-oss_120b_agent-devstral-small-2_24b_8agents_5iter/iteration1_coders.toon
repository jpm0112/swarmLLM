    direction: "Explore a hybrid metaheuristic that combines ant colony optimization for constructing operation sequences with a local search (e.g., 2‑opt) to improve makespan."
    source_refs[0]:
    approach: Hybrid metaheuristic combining Ant Colony Optimization (ACO) for sequence construction with 2-opt local search for makespan improvement
    code: "import time\nimport random\nimport numpy as np\nfrom collections import defaultdict\n\nTIMEOUT_SEC = 120\n_START_TIME = time.time()\n\ndef solve(jobs: list[list[dict]]) -> list[list[dict]]:\n    num_jobs = len(jobs)\n    num_machines = max(op['machine'] for job in jobs for op in job) + 1\n    \n    # Precompute operation indices for each job\n    op_indices = [list(range(len(job))) for job in jobs]\n    \n    # Initialize best solution\n    best_solution = None\n    best_makespan = float('inf')\n    \n    # ACO parameters\n    num_ants = min(20, num_jobs * 2)\n    evaporation_rate = 0.5\n    alpha = 1.0  # pheromone importance\n    beta = 2.0   # heuristic importance\n    \n    # Initialize pheromone matrix (job -> operation -> next job)\n    pheromone = defaultdict(lambda: defaultdict(lambda: 1.0))\n    \n    def evaluate_solution(sequence):\n        \"\"\"Evaluate a job sequence and return makespan\"\"\"\n        machine_availability = [0] * num_machines\n        job_completion = [0] * num_jobs\n        \n        # Create a copy of jobs with start times\n        scheduled_jobs = [job.copy() for job in jobs]\n        \n        for job_idx in sequence:\n            for op_idx, op in enumerate(jobs[job_idx]):\n                machine = op['machine']\n                duration = op['duration']\n                \n                # Start time is max of machine availability and previous operation completion\n                start = max(machine_availability[machine], job_completion[job_idx])\n                \n                # Update machine and job completion times\n                machine_availability[machine] = start + duration\n                job_completion[job_idx] = start + duration\n                \n                # Store start time\n                scheduled_jobs[job_idx][op_idx]['start'] = start\n        \n        return max(job_completion), scheduled_jobs\n    \n    def construct_solution():\n        \"\"\"Construct a solution using ACO\"\"\"\n        sequence = []\n        available_jobs = set(range(num_jobs))\n        \n        while available_jobs:\n            current_job = random.choice(list(available_jobs))\n            sequence.append(current_job)\n            available_jobs.remove(current_job)\n        \n        return sequence\n    \n    def local_search(sequence):\n        \"\"\"Improve solution using 2-opt local search\"\"\"\n        improved = True\n        best_seq = sequence.copy()\n        best_makespan, _ = evaluate_solution(best_seq)\n        \n        while improved and (time.time() - _START_TIME) < 0.8 * TIMEOUT_SEC:\n            improved = False\n            for i in range(len(best_seq)):\n                for j in range(i + 1, len(best_seq)):\n                    # Create new sequence by swapping i and j\n                    new_seq = best_seq.copy()\n                    new_seq[i], new_seq[j] = new_seq[j], new_seq[i]\n                    \n                    # Evaluate new sequence\n                    new_makespan, _ = evaluate_solution(new_seq)\n                    \n                    if new_makespan < best_makespan:\n                        best_makespan = new_makespan\n                        best_seq = new_seq\n                        improved = True\n                        break\n                if improved:\n                    break\n        \n        return best_seq\n    \n    # Main optimization loop\n    while (time.time() - _START_TIME) < 0.8 * TIMEOUT_SEC:\n        # Construct solution using ACO\n        sequence = construct_solution()\n        \n        # Apply local search\n        improved_sequence = local_search(sequence)\n        \n        # Evaluate\n        makespan, scheduled_jobs = evaluate_solution(improved_sequence)\n        \n        # Update best solution\n        if makespan < best_makespan:\n            best_makespan = makespan\n            best_solution = scheduled_jobs\n            \n        # Update pheromones (simplified)\n        for i in range(len(improved_sequence) - 1):\n            job1 = improved_sequence[i]\n            job2 = improved_sequence[i + 1]\n            pheromone[job1][job2] *= (1 - evaporation_rate)\n            pheromone[job1][job2] += 1.0 / makespan\n    \n    # If no solution found (shouldn't happen), return greedy solution\n    if best_solution is None:\n        sequence = list(range(num_jobs))\n        best_makespan, best_solution = evaluate_solution(sequence)\n    \n    return best_solution"
