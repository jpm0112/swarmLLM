    source_refs[0]:
    approach: Fixed greedy scheduling with priority heuristics and proper schedule initialization
    code: "import time\n\ndef solve(jobs: list[list[dict]]) -> list[list[dict]]:\n    # Predefined timeout handling\n    global TIMEOUT_SEC, _START_TIME\n    timeout = TIMEOUT_SEC * 0.8\n    \n    # Extract basic instance features\n    n_jobs = len(jobs)\n    n_machines = max(max(op['machine'] for op in job) for job in jobs) + 1\n    \n    # Greedy scheduling with priority heuristics\n    schedule = [[] for _ in range(n_jobs)]\n    machine_availability = [0] * n_machines\n    job_completion = [0] * n_jobs\n    \n    # Create list of all operations with their metadata\n    operations = []\n    for job_idx, job in enumerate(jobs):\n        for op_idx, operation in enumerate(job):\n            operations.append({\n                'job_idx': job_idx,\n                'op_idx': op_idx,\n                'machine': operation['machine'],\n                'duration': operation['duration'],\n                'job': job\n            })\n    \n    # Sort operations by priority (lower is better)\n    # Using SPT (Shortest Processing Time) + MWKR (Most Work Remaining)\n    def get_priority(op):\n        return op['duration'] + sum(op['duration'] for op in op['job'][op['op_idx']:])\n    \n    operations.sort(key=get_priority)\n    \n    # Process operations in priority order\n    for op in operations:\n        job_idx = op['job_idx']\n        machine = op['machine']\n        duration = op['duration']\n        \n        # Earliest possible start time\n        start_time = max(job_completion[job_idx], machine_availability[machine])\n        \n        # Update machine and job availability\n        machine_availability[machine] = start_time + duration\n        job_completion[job_idx] = start_time + duration\n        \n        # Record the start time\n        schedule[job_idx].append({\n            'machine': machine,\n            'duration': duration,\n            'start': start_time\n        })\n    \n    return schedule"
