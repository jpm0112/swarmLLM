{
  "llm": {
    "backend_kind": "ollama",
    "backend_profile_path": "configs/backends/ollama.local.example.toml",
    "backend_profile_name": "ollama-local",
    "coordinator_model": "qwen2.5-coder:14b",
    "agent_model": "qwen2.5-coder:14b",
    "coordinator_endpoints": [
      {
        "base_url": "http://127.0.0.1:11434/v1",
        "api_key_env": null,
        "api_key": "ollama",
        "weight": 1,
        "label": "ollama-primary"
      }
    ],
    "worker_endpoints": [
      {
        "base_url": "http://127.0.0.1:11434/v1",
        "api_key_env": null,
        "api_key": "ollama",
        "weight": 1,
        "label": "ollama-primary"
      }
    ],
    "temperature_worker": 0.4,
    "temperature_coordinator": 0.4,
    "max_tokens_worker": 4096,
    "max_tokens_coordinator": 8192,
    "request_timeout": 300,
    "coordinator_request_timeout": 600
  },
  "swarm": {
    "num_agents": 1,
    "num_iterations": 1,
    "explore_ratio": 0.5,
    "max_concurrent_agents": 5,
    "agent_retries": 0
  },
  "sandbox": {
    "timeout": 120,
    "max_memory_mb": 512,
    "blocked_imports": [
      "os",
      "sys",
      "subprocess",
      "shutil",
      "pathlib",
      "socket",
      "http",
      "urllib",
      "requests",
      "ftplib",
      "smtplib",
      "imaplib",
      "poplib",
      "webbrowser",
      "antigravity",
      "ctypes",
      "multiprocessing",
      "threading",
      "signal",
      "pickle",
      "shelve",
      "marshal",
      "code",
      "codeop",
      "compile",
      "compileall",
      "importlib",
      "runpy",
      "ensurepip",
      "pip",
      "venv",
      "distutils",
      "setuptools"
    ],
    "pip_packages": [
      "numpy",
      "scipy",
      "networkx",
      "gurobipy"
    ]
  },
  "problem": {
    "problem_type": "job_scheduling",
    "instance_profiles": [
      {
        "name": "5jobs_t0.4",
        "params": {
          "num_jobs": 5,
          "min_processing_time": 1,
          "max_processing_time": 15,
          "due_date_tightness": 0.4
        }
      }
    ],
    "seed": 1048596
  },
  "log": {
    "log_file": "results_log.md",
    "format": "flat_markdown"
  }
}